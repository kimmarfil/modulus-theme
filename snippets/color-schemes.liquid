{% comment %}
  Emit one .color-{{ scheme.id }} CSS class per scheme defined in
  settings_schema.json's `color_scheme_group`.  Each class sets the
  full set of --color-* custom properties used throughout the theme.

  Apply `class="... color-{{ section.settings.color_scheme }}"` on
  any section root to scope its children to that scheme.
{% endcomment %}

{% style %}
  {% for scheme in settings.color_schemes %}
    {%- assign bg      = scheme.settings.background               | default: '#ffffff' -%}
    {%- assign fg      = scheme.settings.text                     | default: '#060809' -%}
    {%- assign heading = scheme.settings.heading                  | default: fg -%}
    {%- assign border  = scheme.settings.border                   | default: '#e5e5e5' -%}
    {%- assign btn_bg  = scheme.settings.button                   | default: fg -%}
    {%- assign btn_tx  = scheme.settings.button_label             | default: bg -%}
    {%- assign link    = scheme.settings.secondary_button_label   | default: fg -%}

    .color-{{ scheme.id }} {
      --color-background: {{ bg }};
      --color-background-rgb: {{ bg | color_to_rgb | remove: 'rgb(' | remove: ')' | replace: ',', ' ' }};
      --color-foreground: {{ fg }};
      --color-foreground-rgb: {{ fg | color_to_rgb | remove: 'rgb(' | remove: ')' | replace: ',', ' ' }};
      --color-foreground-heading: {{ heading }};
      --color-border: {{ border }};
      --color-link: {{ link }};
      --color-primary-button-background: {{ btn_bg }};
      --color-primary-button-text: {{ btn_tx }};
      --color-primary-button-border: {{ btn_bg }};
      --color-primary-button-hover-background: {{ btn_tx }};
      --color-primary-button-hover-text: {{ btn_bg }};
      --color-primary-button-hover-border: {{ btn_bg }};

      color: var(--color-foreground);
      background-color: var(--color-background);
    }
  {% endfor %}
{% endstyle %}
