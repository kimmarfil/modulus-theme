{% comment %}
  Emits .color-scheme-1 .. .color-scheme-5 CSS classes. Each sets the
  full set of --color-* custom properties used throughout the theme.
  Apply `class="... color-{{ section.settings.color_scheme }}"` to any
  section root and its children inherit that scheme's palette.
{% endcomment %}

{% style %}
  {% for i in (1..5) %}
    {% assign bg_key          = 'scheme_' | append: i | append: '_background' %}
    {% assign fg_key          = 'scheme_' | append: i | append: '_foreground' %}
    {% assign heading_key     = 'scheme_' | append: i | append: '_foreground_heading' %}
    {% assign border_key      = 'scheme_' | append: i | append: '_border' %}
    {% assign btn_bg_key      = 'scheme_' | append: i | append: '_primary_button_bg' %}
    {% assign btn_text_key    = 'scheme_' | append: i | append: '_primary_button_text' %}

    {% assign bg      = settings[bg_key]      | default: '#ffffff' %}
    {% assign fg      = settings[fg_key]      | default: '#060809' %}
    {% assign heading = settings[heading_key] | default: fg %}
    {% assign border  = settings[border_key]  | default: '#e5e5e5' %}
    {% assign btn_bg  = settings[btn_bg_key]  | default: fg %}
    {% assign btn_tx  = settings[btn_text_key]| default: bg %}

    .color-scheme-{{ i }} {
      --color-background: {{ bg }};
      --color-background-rgb: {{ bg | color_to_rgb | remove: 'rgb(' | remove: ')' | replace: ',', ' ' }};
      --color-foreground: {{ fg }};
      --color-foreground-rgb: {{ fg | color_to_rgb | remove: 'rgb(' | remove: ')' | replace: ',', ' ' }};
      --color-foreground-heading: {{ heading }};
      --color-border: {{ border }};
      --color-primary-button-background: {{ btn_bg }};
      --color-primary-button-text: {{ btn_tx }};
      --color-primary-button-border: {{ btn_bg }};
      --color-primary-button-hover-background: {{ btn_tx }};
      --color-primary-button-hover-text: {{ btn_bg }};
      --color-primary-button-hover-border: {{ btn_bg }};

      color: var(--color-foreground);
      background-color: var(--color-background);
    }
  {% endfor %}
{% endstyle %}
