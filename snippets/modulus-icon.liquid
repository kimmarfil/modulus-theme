{% comment %}
  Render one of Modulus's bundled icons.

  Usage:
    {% render 'modulus-icon', name: 'arrow-right' %}
    {% render 'modulus-icon', name: 'cart', size: 20, class: 'my-icon' %}

  Accepts:
    name  (string, required) — one of the bundled icon names.
                                Unknown names render nothing silently.
    size  (number, optional) — pixel width + height override. Default 24.
    class (string, optional) — appended to a wrapper <span>.

  All icons use currentColor for stroke/fill, so they inherit the
  parent element's text color.
{% endcomment %}

{%- liquid
  assign icon_name = name | default: ''
  assign icon_size = size | default: 24
  assign icon_class = class | default: ''
-%}

{%- if icon_name != '' -%}
  <span
    class="modulus-icon modulus-icon--{{ icon_name }}{% if icon_class != '' %} {{ icon_class }}{% endif %}"
    style="display:inline-flex;width:{{ icon_size }}px;height:{{ icon_size }}px;line-height:0;"
    aria-hidden="true"
  >
    {%- case icon_name -%}
      {%- when 'arrow-right'       -%}{% render 'icon-arrow-right' %}
      {%- when 'arrow-left'        -%}{% render 'icon-arrow-left' %}
      {%- when 'arrow-up-right'    -%}{% render 'icon-arrow-up-right' %}
      {%- when 'arrow-down'        -%}{% render 'icon-arrow-down' %}
      {%- when 'chevron-down'      -%}{% render 'icon-chevron-down' %}
      {%- when 'plus'              -%}{% render 'icon-plus' %}
      {%- when 'minus'             -%}{% render 'icon-minus' %}
      {%- when 'close'             -%}{% render 'icon-close' %}
      {%- when 'check'             -%}{% render 'icon-check' %}
      {%- when 'search'            -%}{% render 'icon-search' %}
      {%- when 'cart'              -%}{% render 'icon-cart' %}
      {%- when 'account'           -%}{% render 'icon-account' %}
      {%- when 'menu'              -%}{% render 'icon-menu' %}
      {%- when 'heart'             -%}{% render 'icon-heart' %}
      {%- when 'precision'         -%}{% render 'icon-precision' %}
      {%- when 'grid'              -%}{% render 'icon-grid' %}
      {%- when 'layers'            -%}{% render 'icon-layers' %}
      {%- when 'shield'            -%}{% render 'icon-shield' %}
      {%- when 'tool'              -%}{% render 'icon-tool' %}
      {%- when 'package'           -%}{% render 'icon-package' %}
      {%- when 'target'            -%}{% render 'icon-target' %}
      {%- when 'compass'           -%}{% render 'icon-compass' %}
      {%- when 'settings'          -%}{% render 'icon-settings' %}
      {%- when 'play'              -%}{% render 'icon-play' %}
      {%- when 'download'          -%}{% render 'icon-download' %}
      {%- when 'mail'              -%}{% render 'icon-mail' %}
      {%- when 'phone'             -%}{% render 'icon-phone' %}
    {%- endcase -%}
  </span>
{%- endif -%}

{% style %}
  .modulus-icon > svg {
    width: 100%;
    height: 100%;
    display: block;
  }
{% endstyle %}
