{%- comment -%}
  Price-range filter dropdown — matches the visual pattern of
  modulus-filter-dropdown, but renders min/max number inputs bound to
  Shopify's `filter.v.price.gte` / `filter.v.price.lte` params instead
  of a checkbox list.

  Accepts:
    filter — a storefront `collection.filters` entry of type 'price_range'
    id_prefix — unique prefix for input ids
{%- endcomment -%}

{%- liquid
  assign display_max = filter.range_max | money_without_currency
  assign has_active = false
  if filter.min_value.value != blank or filter.max_value.value != blank
    assign has_active = true
  endif
-%}

<div
  class="modulus-filter-dd modulus-filter-dd--price{% if has_active %} has-active{% endif %}"
  data-mod-filter-dd
>
  <button
    type="button"
    class="modulus-filter-dd__trigger"
    data-mod-filter-trigger
    aria-expanded="false"
    aria-haspopup="true"
  >
    <span class="modulus-filter-dd__label">{{ filter.label | escape }}</span>
    {%- if has_active -%}
      <span class="modulus-filter-dd__count" aria-label="Price filter active">•</span>
    {%- endif -%}
    {% render 'modulus-icon', name: 'chevron-down', size: 14 %}
  </button>

  <div class="modulus-filter-dd__panel" data-mod-filter-panel hidden>
    <div class="modulus-filter-dd__panel-inner">
      <span class="modulus-filter-dd__panel-title">{{ filter.label | escape }}</span>

      <div class="modulus-filter-price">
        <div class="modulus-filter-price__inputs">
          <label class="modulus-filter-price__field">
            <span>Min</span>
            <input
              type="number"
              id="{{ id_prefix }}-price-gte"
              name="filter.v.price.gte"
              value="{% if filter.min_value.value %}{{ filter.min_value.value | divided_by: 100.0 }}{% endif %}"
              min="0"
              step="1"
              inputmode="decimal"
              placeholder="0"
            >
          </label>
          <span class="modulus-filter-price__sep" aria-hidden="true">—</span>
          <label class="modulus-filter-price__field">
            <span>Max</span>
            <input
              type="number"
              id="{{ id_prefix }}-price-lte"
              name="filter.v.price.lte"
              value="{% if filter.max_value.value %}{{ filter.max_value.value | divided_by: 100.0 }}{% endif %}"
              min="0"
              step="1"
              inputmode="decimal"
              placeholder="{{ display_max }}"
            >
          </label>
        </div>
        <p class="modulus-filter-price__range">
          Range: {{ 0 | money_without_trailing_zeros }}&nbsp;–&nbsp;{{ filter.range_max | money }}
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .modulus-filter-price {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .modulus-filter-price__inputs {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .modulus-filter-price__field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .modulus-filter-price__field > span {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }
  .modulus-filter-price__field input {
    width: 100%;
    min-width: 0;
    padding: 8px 10px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-body--family);
    font-size: 14px;
    border-radius: 0;
    outline: none;
    -moz-appearance: textfield;
  }
  .modulus-filter-price__field input::-webkit-inner-spin-button,
  .modulus-filter-price__field input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .modulus-filter-price__field input:focus {
    border-color: var(--color-foreground);
  }
  .modulus-filter-price__sep {
    color: rgb(var(--color-foreground-rgb) / 0.5);
    align-self: flex-end;
    padding-bottom: 10px;
    font-size: 14px;
  }
  .modulus-filter-price__range {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    margin: 0;
  }
</style>
