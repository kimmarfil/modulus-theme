{%- comment -%}
  Renders active-filter chips with per-chip remove + "Clear all".

  Accepts:
    filters        — collection.filters (Liquid object)
    collection_url — URL to reset filters (used by Clear all)
{%- endcomment -%}

{%- liquid
  assign total_active = 0
  for filter in filters
    assign total_active = total_active | plus: filter.active_values.size
    if filter.type == 'price_range'
      if filter.min_value.value != blank or filter.max_value.value != blank
        assign total_active = total_active | plus: 1
      endif
    endif
  endfor
-%}

{%- if total_active > 0 -%}
  <div class="modulus-filter-chips" role="region" aria-label="Active filters">
    <ul class="modulus-filter-chips__list" role="list">
      {%- for filter in filters -%}

        {%- comment -%} List-style chips (list, boolean, etc.) {%- endcomment -%}
        {%- for value in filter.active_values -%}
          <li class="modulus-filter-chips__item">
            <a href="{{ value.url_to_remove }}" class="modulus-filter-chips__chip" rel="nofollow">
              <span class="modulus-filter-chips__chip-group">{{ filter.label | escape }}:</span>
              <span class="modulus-filter-chips__chip-value">{{ value.label | escape }}</span>
              {% render 'modulus-icon', name: 'close', size: 10 %}
              <span class="visually-hidden">Remove filter</span>
            </a>
          </li>
        {%- endfor -%}

        {%- comment -%} Price-range chip (stored as min_value / max_value, not active_values) {%- endcomment -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
            {%- liquid
              assign min_label = '0'
              if filter.min_value.value != blank
                assign min_label = filter.min_value.value | money
              endif
              assign max_label = filter.range_max | money
              if filter.max_value.value != blank
                assign max_label = filter.max_value.value | money
              endif
            -%}
            <li class="modulus-filter-chips__item">
              <a href="{{ filter.url_to_remove }}" class="modulus-filter-chips__chip" rel="nofollow">
                <span class="modulus-filter-chips__chip-group">{{ filter.label | escape }}:</span>
                <span class="modulus-filter-chips__chip-value">{{ min_label }}&ndash;{{ max_label }}</span>
                {% render 'modulus-icon', name: 'close', size: 10 %}
                <span class="visually-hidden">Remove filter</span>
              </a>
            </li>
          {%- endif -%}
        {%- endif -%}

      {%- endfor -%}
    </ul>
    {%- if collection_url != blank -%}
      <a href="{{ collection_url }}" class="modulus-filter-chips__clear" rel="nofollow">Clear all</a>
    {%- endif -%}
  </div>
{%- endif -%}
