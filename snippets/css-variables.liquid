{% style %}
  {% # Load font face declarations for each typographic role. %}
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}

  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {{ settings.type_label_font | font_face: font_display: 'swap' }}

  {% # Legacy primary font (Skeleton compatibility). %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}

  :root {
    /* ------ Typography roles ------ */
    --font-heading--family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-heading--weight: {{ settings.type_heading_font.weight }};
    --font-heading--style: {{ settings.type_heading_font.style }};

    --font-body--family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-body--weight: {{ settings.type_body_font.weight }};
    --font-body--style: {{ settings.type_body_font.style }};

    --font-label--family: {{ settings.type_label_font.family }}, {{ settings.type_label_font.fallback_families }};
    --font-label--weight: {{ settings.type_label_font.weight }};
    --font-label--style: {{ settings.type_label_font.style }};

    {% # Skeleton-native primary font (used by base.css / body) %}
    --font-primary--family: {{ settings.type_primary_font.family }}, {{ settings.type_primary_font.fallback_families }};
    --font-primary--style: {{ settings.type_primary_font.style }};
    --font-primary--weight: {{ settings.type_primary_font.weight }};

    {% # Heading H1-H6 aliases so section CSS can address specific levels. %}
    --font-h1--family: var(--font-heading--family);
    --font-h1--weight: var(--font-heading--weight);
    --font-h1--style: var(--font-heading--style);
    --font-h1--letter-spacing: -0.01em;
    --font-h1--case: none;

    --font-h2--family: var(--font-heading--family);
    --font-h2--weight: var(--font-heading--weight);
    --font-h3--family: var(--font-heading--family);
    --font-h4--family: var(--font-heading--family);
    --font-h5--family: var(--font-body--family);
    --font-h5--weight: var(--font-body--weight);
    --font-h6--family: var(--font-body--family);
    --font-paragraph--family: var(--font-body--family);

    /* ------ Layout ------ */
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;

    /* ------ Defaults (from Scheme 1 — overridden per-scheme by color-schemes snippet) ------ */
    --color-background: {{ settings.scheme_1_background | default: settings.background_color }};
    --color-foreground: {{ settings.scheme_1_foreground | default: settings.foreground_color }};
    --color-foreground-heading: {{ settings.scheme_1_foreground_heading | default: settings.scheme_1_foreground | default: settings.foreground_color }};
    --color-foreground-rgb: {{ settings.scheme_1_foreground | default: settings.foreground_color | color_to_rgb | remove: 'rgb(' | remove: ')' | replace: ',', ' ' }};
    --color-border: {{ settings.scheme_1_border | default: '#e5e5e5' }};

    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
  }
{% endstyle %}

{% render 'color-schemes' %}
