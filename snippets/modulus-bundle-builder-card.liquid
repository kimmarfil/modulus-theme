{%- comment -%}
  Modulus Bundle Builder — single product card in the picker grid.

  Accepts:
    product — the product object
{%- endcomment -%}

<article class="modulus-bb__card{% if product.available == false %} is-unavailable{% endif %}">
  <a href="{{ product.url }}" class="modulus-bb__card-media" tabindex="-1" aria-hidden="true">
    {%- if product.featured_image != blank -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        srcset="
          {{ product.featured_image | image_url: width: 300 }} 300w,
          {{ product.featured_image | image_url: width: 600 }} 600w,
          {{ product.featured_image | image_url: width: 900 }} 900w
        "
        sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 25vw"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: '' }}
    {%- endif -%}

    {%- if product.available == false -%}
      <span class="modulus-bb__card-badge">Sold out</span>
    {%- endif -%}
  </a>

  <div class="modulus-bb__card-body">
    <a href="{{ product.url }}" class="modulus-bb__card-title">{{ product.title | escape }}</a>
    <div class="modulus-bb__card-price">
      {%- if product.compare_at_price > product.price -%}
        <span class="modulus-bb__card-price--sale">{{ product.price | money }}</span>
        <span class="modulus-bb__card-price--compare"><s>{{ product.compare_at_price | money }}</s></span>
      {%- else -%}
        <span>{{ product.price | money }}</span>
      {%- endif -%}
    </div>
    {% render 'modulus-product-swatches', product: product, max: 4 %}
  </div>

  <button
    type="button"
    class="modulus-bb__card-add"
    data-mod-bb-add
    aria-label="Add {{ product.title | escape }} to bundle"
  >
    <span data-mod-bb-add-label>Add to bundle</span>
  </button>
</article>

<style>
  .modulus-bb__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0 0 12px;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    transition: border-color 0.2s ease;
  }
  .modulus-bb__card.is-unavailable { opacity: 0.5; }
  .modulus-bb__card-media {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    position: relative;
  }
  .modulus-bb__card-media img,
  .modulus-bb__card-media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .modulus-bb__card-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--color-foreground);
    color: var(--color-background);
    padding: 3px 8px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .modulus-bb__card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 16px;
  }
  .modulus-bb__card-title {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    line-height: 1.3;
    color: var(--color-foreground);
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .modulus-bb__card-price {
    font-family: var(--font-body--family);
    font-size: 13px;
    color: var(--color-foreground);
  }
  .modulus-bb__card-price--compare {
    color: rgb(var(--color-foreground-rgb) / 0.5);
    margin-left: 6px;
  }
  .modulus-bb__card-add {
    margin: 0 16px;
    padding: 10px 16px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: transparent;
    color: var(--color-foreground);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .modulus-bb__card-add:hover {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
  .modulus-bb__card-add:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: transparent;
    color: var(--color-foreground);
  }
  .modulus-bb__card-wrap.is-selected .modulus-bb__card-add {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
</style>
