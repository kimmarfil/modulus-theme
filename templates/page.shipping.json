/*
 * ------------------------------------------------------------
 * Modulus Shipping / Policies page template.
 *
 * Assign to a Shipping / Returns page in Shopify admin. Renders the
 * page title and the merchant-authored body in editorial typography,
 * with an FAQ-style accordion below for the most common follow-up
 * questions.
 * ------------------------------------------------------------
 */
{
  "sections": {
    "page-header": {
      "type": "modulus-page",
      "settings": {
        "label_text": "Policies",
        "label_number": "01",
        "heading_override": "Shipping & returns",
        "subtitle": "<p>Plain-language summary of where we ship, how long it takes, and what to do if something isn't right.</p>",
        "content_max_width": 760,
        "padding_y": 96
      }
    },
    "faq": {
      "type": "modulus-faq",
      "settings": {
        "label_text": "Details",
        "label_number": "02",
        "heading": "",
        "layout": "stack",
        "intro": ""
      },
      "blocks": {
        "s1": {
          "type": "qa",
          "settings": {
            "question": "Where do you ship?",
            "answer": "<p>Most countries, with a few exceptions we're actively working to add. Any address that's deliverable by our carriers (DHL, FedEx, national post) is available at checkout. If your address isn't accepted, email us — we'll often ship there manually.</p>",
            "open_by_default": true
          }
        },
        "s2": {
          "type": "qa",
          "settings": {
            "question": "How much does shipping cost?",
            "answer": "<p>Rates are calculated live at checkout based on destination and weight. Orders over a threshold (shown on the cart page) ship free domestically.</p>"
          }
        },
        "s3": {
          "type": "qa",
          "settings": {
            "question": "How long does an order take to arrive?",
            "answer": "<p>Domestic: 3–5 business days after dispatch. International: 7–14 business days after dispatch. Dispatch itself happens within 2 business days of order confirmation.</p>"
          }
        },
        "s4": {
          "type": "qa",
          "settings": {
            "question": "How do I return something?",
            "answer": "<p>Email us within 30 days of delivery with your order number. We'll send a pre-paid return label (domestic) or return instructions (international). Once we receive and inspect the return, we refund to the original payment method within 3 business days.</p>"
          }
        },
        "s5": {
          "type": "qa",
          "settings": {
            "question": "What about damaged or wrong items?",
            "answer": "<p>Always our fault, always on us. Email a photo and your order number; we'll overnight a replacement at no cost, no return needed.</p>"
          }
        }
      },
      "block_order": ["s1", "s2", "s3", "s4", "s5"]
    }
  },
  "order": [
    "page-header",
    "faq"
  ]
}
