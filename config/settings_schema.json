[
  {
    "name": "theme_info",
    "theme_name": "Modulus",
    "theme_version": "0.1.0",
    "theme_author": "Kim Marfil",
    "theme_documentation_url": "https://github.com/kimmarfil/modulus-theme#readme",
    "theme_support_url": "https://github.com/kimmarfil/modulus-theme/issues"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "chakra_petch_n6",
        "label": "Heading font",
        "info": "Used for section headings and titles."
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "manrope_n4",
        "label": "Body font",
        "info": "Used for paragraph copy, body text, and descriptions."
      },
      {
        "type": "font_picker",
        "id": "type_label_font",
        "default": "inter_n5",
        "label": "Label font",
        "info": "Used for tiny uppercase labels and button text."
      },
      {
        "type": "header",
        "content": "Primary font (Skeleton fallback)"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "manrope_n4",
        "label": "Primary font",
        "info": "Fallback for anything not scoped to heading / body / label."
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Page width",
        "options": [
          { "value": "90rem", "label": "Narrow (1440px)" },
          { "value": "100rem", "label": "Standard (1600px)" },
          { "value": "110rem", "label": "Wide (1760px)" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Page margin",
        "default": 24
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#ffffff"
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#060809"
          },
          {
            "type": "color",
            "id": "heading",
            "label": "Heading",
            "default": "#060809"
          },
          {
            "type": "color",
            "id": "border",
            "label": "Border / divider",
            "default": "#e5e5e5"
          },
          {
            "type": "color",
            "id": "button",
            "label": "Button background",
            "default": "#060809"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "Button text",
            "default": "#ffffff"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "Secondary button text / link",
            "default": "#060809"
          }
        ],
        "role": {
          "text": "text",
          "background": { "solid": "background" },
          "links": "secondary_button_label",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "secondary_button_label"
        }
      }
    ]
  },
  {
    "name": "Defaults",
    "settings": [
      {
        "type": "header",
        "content": "Legacy colors (Skeleton compatibility)"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#ffffff",
        "label": "Site background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#060809",
        "label": "Site foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "Input corner radius",
        "default": 0
      }
    ]
  }
]
