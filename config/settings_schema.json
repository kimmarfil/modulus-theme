[
  {
    "name": "theme_info",
    "theme_name": "Modulus",
    "theme_version": "0.1.0",
    "theme_author": "Kim Marfil",
    "theme_documentation_url": "https://github.com/kimmarfil/modulus-theme#readme",
    "theme_support_url": "https://github.com/kimmarfil/modulus-theme/issues"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "chakra_petch_n6",
        "label": "Heading font",
        "info": "Used for section headings and titles. Industrial / display-weight by default."
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "manrope_n4",
        "label": "Body font",
        "info": "Used for paragraph copy, body text, and descriptions."
      },
      {
        "type": "font_picker",
        "id": "type_label_font",
        "default": "inter_n5",
        "label": "Label font",
        "info": "Used for tiny uppercase labels (\u201cSERVICES\u201d, \u201c/01\u201d, button text)."
      },
      {
        "type": "header",
        "content": "Primary font (legacy \u2014 used for fallback)"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "manrope_n4",
        "label": "Primary font",
        "info": "Fallback for anything not scoped to heading / body / label."
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Page width",
        "options": [
          {
            "value": "90rem",
            "label": "Narrow (1440px)"
          },
          {
            "value": "100rem",
            "label": "Standard (1600px)"
          },
          {
            "value": "110rem",
            "label": "Wide (1760px)"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Page margin",
        "default": 24
      }
    ]
  },
