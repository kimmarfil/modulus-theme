{% comment %}
  Dev-only section — renders every Modulus icon in a grid for visual QA.
  Delete before Theme Store submission, or keep behind a dev flag.
{% endcomment %}

<section class="modulus-icon-gallery color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}">
  <div class="modulus-icon-gallery__inner">
    <h2 class="modulus-icon-gallery__heading">Modulus Icon Set</h2>
    <p class="modulus-icon-gallery__sub">{{ section.settings.note }}</p>

    <ul class="modulus-icon-gallery__grid">
      {%- assign icon_names = 'arrow-right,arrow-left,arrow-up-right,arrow-down,chevron-down,plus,minus,close,check,search,cart,account,menu,heart,precision,grid,layers,shield,tool,package,target,compass,settings,play,download,mail,phone' | split: ',' -%}
      {%- for name in icon_names -%}
        <li class="modulus-icon-gallery__item">
          {% render 'modulus-icon', name: name, size: 32 %}
          <span class="modulus-icon-gallery__label">{{ name }}</span>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
  .modulus-icon-gallery {
    padding: var(--mod-section-py) var(--mod-section-px);
    background: var(--color-background);
    color: var(--color-foreground);
  }
  .modulus-icon-gallery__inner {
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }
  .modulus-icon-gallery__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(28px, 3vw, 40px);
    margin: 0 0 8px;
  }
  .modulus-icon-gallery__sub {
    font-family: var(--font-body--family);
    color: rgb(var(--color-foreground-rgb) / 0.6);
    margin: 0 0 32px;
  }
  .modulus-icon-gallery__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .modulus-icon-gallery__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 24px 12px;
    background: var(--color-background);
  }
  .modulus-icon-gallery__label {
    font-family: var(--font-label--family);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Icon Gallery (dev)",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full",        "label": "Full viewport" }
      ],
      "default": "constrained"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Subheading",
      "default": "Every icon bundled with the Modulus theme. Hover to see its name."
    }
  ],
  "presets": [
    { "name": "Icon Gallery (dev)" }
  ]
}
{% endschema %}
