{% comment %}
  Modulus Footer — oversized CTA headline + 4-column editorial grid:
  brand / nav / contact / copyright+social.

  Enable as a group section (sections/footer-group.json) to replace
  Skeleton's default footer.
{% endcomment %}

<footer class="modulus-footer color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="
    --mf-cta-size: {{ section.settings.cta_size }}px;
    --mf-brand-size: {{ section.settings.brand_size }}px;
    --mf-gap: {{ section.settings.gap }}px;
    --mf-py-top: {{ section.settings.padding_top }}px;
    --mf-py-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="modulus-footer__inner">

    {%- if section.settings.cta_enabled and section.settings.cta_text != blank -%}
      <div class="modulus-footer__cta-row">
        <a class="modulus-footer__cta" href="{{ section.settings.cta_link | default: '#' }}">
          <span>{{ section.settings.cta_text }}</span>
          <span class="modulus-footer__cta-arrow" aria-hidden="true">
            {% render 'modulus-icon', name: 'arrow-up-right', size: 48 %}
          </span>
        </a>
      </div>
    {%- endif -%}

    <div class="modulus-footer__grid">

      {% comment %} Column 1: Brand + Tagline {% endcomment %}
      <div class="modulus-footer__col">
        {%- if section.settings.brand_name != blank -%}
          <h2 class="modulus-footer__brand">{{ section.settings.brand_name }}</h2>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <div class="modulus-footer__tagline">{{ section.settings.tagline }}</div>
        {%- endif -%}
      </div>

      {% comment %} Column 2: Nav links (from blocks) {% endcomment %}
      <div class="modulus-footer__col">
        {%- if section.settings.nav_heading != blank -%}
          <span class="modulus-footer__label">{{ section.settings.nav_heading }}</span>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <nav class="modulus-footer__nav" aria-label="Footer navigation">
            {%- for block in section.blocks -%}
              {%- if block.type == 'nav_link' -%}
                <a class="modulus-footer__link" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
                  {{- block.settings.label -}}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}
      </div>

      {% comment %} Column 3: Contact {% endcomment %}
      <div class="modulus-footer__col">
        {%- if section.settings.contact_heading != blank -%}
          <span class="modulus-footer__label">{{ section.settings.contact_heading }}</span>
        {%- endif -%}
        {%- if section.settings.contact_text != blank -%}
          <div class="modulus-footer__text">{{ section.settings.contact_text }}</div>
        {%- endif -%}
      </div>

      {% comment %} Column 4: Copyright + Social {% endcomment %}
      <div class="modulus-footer__col">
        {%- if section.settings.copyright_heading != blank -%}
          <span class="modulus-footer__label">{{ section.settings.copyright_heading }}</span>
        {%- endif -%}
        {%- if section.settings.copyright_text != blank -%}
          <div class="modulus-footer__text">{{ section.settings.copyright_text }}</div>
        {%- endif -%}
        {%- assign has_social = false -%}
        {%- if section.settings.social_url_1 != blank or section.settings.social_url_2 != blank or section.settings.social_url_3 != blank -%}
          {%- assign has_social = true -%}
        {%- endif -%}
        {%- if has_social -%}
          <div class="modulus-footer__social">
            {%- if section.settings.social_url_1 != blank -%}
              <a class="modulus-footer__social-link" href="{{ section.settings.social_url_1 }}" target="_blank" rel="noopener">{{ section.settings.social_label_1 }}</a>
            {%- endif -%}
            {%- if section.settings.social_url_2 != blank -%}
              <a class="modulus-footer__social-link" href="{{ section.settings.social_url_2 }}" target="_blank" rel="noopener">{{ section.settings.social_label_2 }}</a>
            {%- endif -%}
            {%- if section.settings.social_url_3 != blank -%}
              <a class="modulus-footer__social-link" href="{{ section.settings.social_url_3 }}" target="_blank" rel="noopener">{{ section.settings.social_label_3 }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- if section.settings.show_locale_selector -%}
      <div class="modulus-footer__locale">
        {% render 'modulus-locale-selector', variant: 'inline' %}
      </div>
    {%- endif -%}

  </div>
</footer>

{% stylesheet %}
  .modulus-footer {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--mf-py-top, 96px) var(--mod-section-px) var(--mf-py-bottom, 56px);
  }

  .modulus-footer__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  .modulus-footer__locale {
    margin-top: var(--mod-gap-lg);
    padding-top: var(--mod-gap-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 640px) {
    .modulus-footer__locale { justify-content: flex-start; }
  }

  /* ---- CTA row ---- */
  .modulus-footer__cta-row {
    padding-bottom: var(--mod-gap-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--mod-gap-xl);
  }

  .modulus-footer__cta {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--mf-cta-size, clamp(48px, 8vw, 120px));
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.0;
    text-decoration: underline;
    text-underline-offset: 8px;
    text-decoration-thickness: 2px;
    transition: opacity var(--mod-duration-base) var(--mod-ease),
                gap var(--mod-duration-fast) var(--mod-ease);
    cursor: pointer;
  }

  .modulus-footer__cta:hover {
    opacity: 0.7;
    gap: 24px;
  }

  /* ---- 4-column grid ---- */
  .modulus-footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--mf-gap, 40px);
  }

  .modulus-footer__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .modulus-footer__label {
    font-family: var(--font-label--family);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin-bottom: 4px;
  }

  .modulus-footer__brand {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--mf-brand-size, 32px);
    text-transform: uppercase;
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1;
    margin: 0 0 8px;
  }

  .modulus-footer__tagline,
  .modulus-footer__text {
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-footer__tagline p,
  .modulus-footer__text p {
    margin: 0 0 0.5em;
  }

  .modulus-footer__tagline p:last-child,
  .modulus-footer__text p:last-child {
    margin-bottom: 0;
  }

  .modulus-footer__text a {
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    transition: opacity var(--mod-duration-fast) var(--mod-ease);
  }

  .modulus-footer__text a:hover {
    opacity: 0.7;
  }

  /* Nav column */
  .modulus-footer__nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .modulus-footer__link {
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
    text-decoration: none;
    transition: opacity var(--mod-duration-fast) var(--mod-ease);
    width: fit-content;
  }

  .modulus-footer__link:hover {
    opacity: 0.6;
  }

  /* Social links */
  .modulus-footer__social {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  .modulus-footer__social-link {
    font-family: var(--font-label--family);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    transition: opacity var(--mod-duration-fast) var(--mod-ease);
    width: fit-content;
  }

  .modulus-footer__social-link:hover {
    opacity: 0.6;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .modulus-footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 24px;
    }
  }

  @media (max-width: 768px) {
    .modulus-footer {
      padding-top: 56px;
      padding-bottom: 40px;
    }
    .modulus-footer__cta-row {
      padding-bottom: var(--mod-gap-lg);
      margin-bottom: var(--mod-gap-lg);
    }
    .modulus-footer__cta {
      font-size: clamp(32px, 9vw, 52px);
      text-underline-offset: 4px;
      gap: 10px;
    }
    .modulus-footer__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .modulus-footer__brand {
      font-size: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "CTA (top)"
    },
    {
      "type": "checkbox",
      "id": "cta_enabled",
      "label": "Show oversized CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Get in touch"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "cta_size",
      "label": "CTA text size (desktop)",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Brand column"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Modulus"
    },
    {
      "type": "richtext",
      "id": "tagline",
      "label": "Tagline",
      "default": "<p>Design-led commerce for precision brands.</p>"
    },
    {
      "type": "range",
      "id": "brand_size",
      "label": "Brand name size",
      "min": 20,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Navigate column"
    },
    {
      "type": "text",
      "id": "nav_heading",
      "label": "Nav heading",
      "default": "Navigate"
    },
    {
      "type": "header",
      "content": "Contact column"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact"
    },
    {
      "type": "richtext",
      "id": "contact_text",
      "label": "Contact text",
      "default": "<p>hello@example.com</p><p>City, Country</p>"
    },
    {
      "type": "header",
      "content": "Copyright column"
    },
    {
      "type": "text",
      "id": "copyright_heading",
      "label": "Copyright heading",
      "default": "Connect"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "© 2026 Modulus"
    },
    {
      "type": "text",
      "id": "social_label_1",
      "label": "Social 1 label",
      "default": "Instagram"
    },
    {
      "type": "url",
      "id": "social_url_1",
      "label": "Social 1 URL"
    },
    {
      "type": "text",
      "id": "social_label_2",
      "label": "Social 2 label",
      "default": "LinkedIn"
    },
    {
      "type": "url",
      "id": "social_url_2",
      "label": "Social 2 URL"
    },
    {
      "type": "text",
      "id": "social_label_3",
      "label": "Social 3 label"
    },
    {
      "type": "url",
      "id": "social_url_3",
      "label": "Social 3 URL"
    },
    {
      "type": "header",
      "content": "Localization"
    },
    {
      "type": "checkbox",
      "id": "show_locale_selector",
      "label": "Show language / country selector",
      "info": "Appears below the footer columns. Only renders if the store has more than one market or language enabled.",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full",        "label": "Full viewport" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Column gap",
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Home"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Modulus Footer",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Home" } },
        { "type": "nav_link", "settings": { "label": "Shop" } },
        { "type": "nav_link", "settings": { "label": "About" } },
        { "type": "nav_link", "settings": { "label": "Contact" } }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
