{% comment %}
  Modulus Article — single article / journal entry detail view.
  Header + optional featured image + richtext body + tags + share links
  + optional comments form + prev/next navigation.
{% endcomment %}

{%- liquid
  assign article_url_full = shop.secure_url | append: article.url
  assign share_title = article.title | url_encode
  assign share_url = article_url_full | url_encode
-%}

<article
  id="modulus-article-{{ section.id }}"
  class="modulus-article color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="
    --ma-content-width: {{ section.settings.content_max_width }}px;
    --ma-py: {{ section.settings.padding_y }}px;
  "
>
  <div class="modulus-article__inner">

    {%- if section.settings.show_breadcrumb -%}
      <nav class="modulus-article__breadcrumb" aria-label="Breadcrumb" data-mod-reveal>
        <a href="{{ routes.root_url }}">Home</a>
        <span aria-hidden="true">/</span>
        <a href="{{ blog.url }}">{{ blog.title | escape }}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{{ article.title | escape | truncate: 60 }}</span>
      </nav>
    {%- endif -%}

    <header class="modulus-article__header" data-mod-reveal>
      <div class="modulus-article__kicker">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: section.settings.date_format | default: '%B %-d, %Y' }}
        </time>
        {%- if article.author != blank -%}
          <span aria-hidden="true"> · </span>
          <span class="modulus-article__author">{{ article.author | escape }}</span>
        {%- endif -%}
      </div>

      <h1 class="modulus-article__title">{{ article.title | escape }}</h1>

      {%- if article.excerpt != blank -%}
        <div class="modulus-article__excerpt">{{ article.excerpt }}</div>
      {%- endif -%}

      {%- if article.tags.size > 0 -%}
        <ul class="modulus-article__tags" role="list">
          {%- for tag in article.tags -%}
            <li><a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag | escape }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </header>

    {%- if article.image != blank and section.settings.show_featured_image -%}
      <figure class="modulus-article__hero{% if section.settings.hero_full_bleed %} is-full-bleed{% endif %}" data-mod-reveal data-mod-reveal-delay="80">
        <img
          src="{{ article.image | image_url: width: 1800 }}"
          srcset="
            {{ article.image | image_url: width: 800 }} 800w,
            {{ article.image | image_url: width: 1200 }} 1200w,
            {{ article.image | image_url: width: 1800 }} 1800w,
            {{ article.image | image_url: width: 2400 }} 2400w
          "
          sizes="{% if section.settings.hero_full_bleed %}100vw{% else %}(min-width: 1024px) 80vw, 100vw{% endif %}"
          alt="{{ article.image.alt | default: article.title | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ article.image.width }}"
          height="{{ article.image.height }}"
        >
      </figure>
    {%- endif -%}

    <div class="modulus-article__body-wrap">
      <div class="modulus-article__body rte" data-mod-reveal data-mod-reveal-delay="120">
        {{ article.content }}
      </div>

      {%- if section.settings.show_share -%}
        <div class="modulus-article__share">
          <span class="modulus-article__share-label">Share</span>
          <ul class="modulus-article__share-list" role="list">
            <li>
              <a href="https://twitter.com/intent/tweet?text={{ share_title }}&url={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on X / Twitter">
                X
              </a>
            </li>
            <li>
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on Facebook">
                Facebook
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on LinkedIn">
                LinkedIn
              </a>
            </li>
            <li>
              <a href="mailto:?subject={{ share_title }}&body={{ share_url }}" aria-label="Share by email">
                Email
              </a>
            </li>
          </ul>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ===== COMMENTS ===== {%- endcomment -%}
    {%- if blog.comments_enabled? -%}
      <section class="modulus-article__comments" aria-label="Comments" data-mod-reveal>
        <h2 class="modulus-article__comments-heading">
          {%- if article.comments_count == 0 -%}
            Comments
          {%- else -%}
            {{ article.comments_count }} comment{% if article.comments_count != 1 %}s{% endif %}
          {%- endif -%}
        </h2>

        {%- if article.comments_count > 0 -%}
          <ul class="modulus-article__comments-list" role="list">
            {%- for comment in article.comments -%}
              <li class="modulus-article__comment" id="comment-{{ comment.id }}">
                <div class="modulus-article__comment-meta">
                  <span class="modulus-article__comment-author">{{ comment.author | escape }}</span>
                  <time datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">
                    {{ comment.created_at | date: '%B %-d, %Y' }}
                  </time>
                </div>
                <div class="modulus-article__comment-body">{{ comment.content }}</div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {% form 'new_comment', article %}
          <div class="modulus-article__comment-form">
            {%- if form.errors -%}
              <div class="modulus-article__form-errors" role="alert">
                <p>Please correct the following:</p>
                <ul>
                  {%- for field in form.errors -%}
                    <li>{{ form.errors.messages[field] | escape }}</li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- elsif form.posted_successfully? -%}
              <div class="modulus-article__form-success" role="status">
                {%- if blog.moderated? -%}
                  Your comment was received and will appear after it is approved.
                {%- else -%}
                  Your comment has been posted.
                {%- endif -%}
              </div>
            {%- endif -%}

            <h3 class="modulus-article__form-heading">Leave a comment</h3>
            {%- if blog.moderated? -%}
              <p class="modulus-article__form-note">Comments are moderated before appearing.</p>
            {%- endif -%}

            <div class="modulus-article__form-row">
              <label for="comment-author-{{ section.id }}">Name</label>
              <input
                type="text"
                id="comment-author-{{ section.id }}"
                name="comment[author]"
                value="{{ form.author | escape }}"
                required
              >
            </div>

            <div class="modulus-article__form-row">
              <label for="comment-email-{{ section.id }}">Email</label>
              <input
                type="email"
                id="comment-email-{{ section.id }}"
                name="comment[email]"
                value="{{ form.email | escape }}"
                required
              >
            </div>

            <div class="modulus-article__form-row">
              <label for="comment-body-{{ section.id }}">Comment</label>
              <textarea
                id="comment-body-{{ section.id }}"
                name="comment[body]"
                rows="5"
                required
              >{{ form.body | escape }}</textarea>
            </div>

            <button type="submit" class="mod-btn mod-btn--primary">
              <span>Post comment</span>
              <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
            </button>
          </div>
        {% endform %}
      </section>
    {%- endif -%}

    {%- comment -%} ===== PREV / NEXT ===== {%- endcomment -%}
    {%- if section.settings.show_prev_next -%}{%- if blog.previous_article or blog.next_article -%}
      <nav class="modulus-article__adjacent" aria-label="Article navigation" data-mod-reveal>
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article }}" class="modulus-article__adjacent-link modulus-article__adjacent-link--prev">
            <span class="modulus-article__adjacent-label">
              {% render 'modulus-icon', name: 'arrow-left', size: 12 %}
              <span>Previous</span>
            </span>
            <span class="modulus-article__adjacent-title">Read the previous article</span>
          </a>
        {%- endif -%}
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article }}" class="modulus-article__adjacent-link modulus-article__adjacent-link--next">
            <span class="modulus-article__adjacent-label">
              <span>Next</span>
              {% render 'modulus-icon', name: 'arrow-right', size: 12 %}
            </span>
            <span class="modulus-article__adjacent-title">Read the next article</span>
          </a>
        {%- endif -%}
      </nav>
    {%- endif -%}{%- endif -%}

  </div>
</article>

{% stylesheet %}
  .modulus-article {
    display: block;
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--ma-py, var(--mod-section-py)) var(--mod-section-px);
  }

  .modulus-article__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  /* ---- breadcrumb ---- */

  .modulus-article__breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin-bottom: var(--mod-gap-lg);
  }

  .modulus-article__breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .modulus-article__breadcrumb a:hover {
    color: var(--color-foreground);
  }

  /* ---- header ---- */

  .modulus-article__header {
    max-width: var(--ma-content-width, 760px);
    margin: 0 auto var(--mod-gap-xl);
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
  }

  .modulus-article__kicker {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  .modulus-article__author {
    color: var(--color-foreground);
  }

  h1.modulus-article__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(32px, 5.5vw, 72px);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .modulus-article__excerpt {
    font-family: var(--font-body--family);
    font-size: clamp(16px, 1.3vw, 20px);
    color: rgb(var(--color-foreground-rgb) / 0.75);
    line-height: 1.55;
    margin-top: 8px;
  }

  .modulus-article__excerpt p { margin: 0; }

  .modulus-article__tags {
    list-style: none;
    padding: 0;
    margin: 8px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .modulus-article__tags a {
    display: inline-block;
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .modulus-article__tags a:hover {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  /* ---- hero image ---- */

  .modulus-article__hero {
    margin: 0 0 var(--mod-gap-xl);
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .modulus-article__hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .modulus-article__hero.is-full-bleed {
    margin-left: calc(var(--mod-section-px, 24px) * -1);
    margin-right: calc(var(--mod-section-px, 24px) * -1);
    max-width: none;
  }

  /* ---- body ---- */

  .modulus-article__body-wrap {
    display: grid;
    grid-template-columns: 1fr minmax(0, var(--ma-content-width, 760px)) 1fr;
    gap: var(--mod-gap-md);
  }

  .modulus-article__body {
    grid-column: 2;
    font-family: var(--font-body--family);
    font-size: clamp(16px, 1.15vw, 18px);
    color: var(--color-foreground);
    line-height: 1.75;
  }

  .modulus-article__body p { margin: 0 0 1.2em; }
  .modulus-article__body p:last-child { margin-bottom: 0; }
  .modulus-article__body h2,
  .modulus-article__body h3,
  .modulus-article__body h4 {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    color: var(--color-foreground-heading, var(--color-foreground));
    letter-spacing: -0.005em;
    line-height: 1.2;
    margin: 2em 0 0.6em;
  }
  .modulus-article__body h2 { font-size: clamp(22px, 2.2vw, 32px); }
  .modulus-article__body h3 { font-size: clamp(18px, 1.7vw, 24px); }
  .modulus-article__body h4 { font-size: clamp(16px, 1.4vw, 20px); }
  .modulus-article__body a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .modulus-article__body blockquote {
    margin: 1.5em 0;
    padding-left: 24px;
    border-left: 3px solid var(--color-foreground);
    font-family: var(--font-heading--family);
    font-size: 1.2em;
    line-height: 1.4;
    color: var(--color-foreground-heading, var(--color-foreground));
  }
  .modulus-article__body ul,
  .modulus-article__body ol {
    padding-left: 1.3em;
    margin: 0 0 1.2em;
  }
  .modulus-article__body li { margin-bottom: 0.4em; }
  .modulus-article__body img,
  .modulus-article__body iframe {
    max-width: 100%;
    height: auto;
    margin: 1.5em 0;
    display: block;
  }
  .modulus-article__body hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2.5em 0;
  }
  .modulus-article__body code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    padding: 2px 6px;
    background: rgb(var(--color-foreground-rgb) / 0.06);
    border-radius: 3px;
  }
  .modulus-article__body pre {
    background: rgb(var(--color-foreground-rgb) / 0.04);
    padding: 16px;
    overflow-x: auto;
    font-size: 0.9em;
  }
  .modulus-article__body pre code {
    background: none;
    padding: 0;
  }

  /* ---- share ---- */

  .modulus-article__share {
    grid-column: 2;
    margin-top: var(--mod-gap-lg);
    padding-top: var(--mod-gap-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .modulus-article__share-label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  .modulus-article__share-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 20px;
  }

  .modulus-article__share-list a {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.2s ease;
  }

  .modulus-article__share-list a:hover {
    border-bottom-color: var(--color-foreground);
  }

  /* ---- comments ---- */

  .modulus-article__comments {
    max-width: var(--ma-content-width, 760px);
    margin: var(--mod-gap-xl) auto 0;
    padding-top: var(--mod-gap-lg);
    border-top: 1px solid var(--color-border);
  }

  h2.modulus-article__comments-heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(22px, 2.4vw, 32px);
    color: var(--color-foreground-heading, var(--color-foreground));
    margin: 0 0 var(--mod-gap-md);
  }

  .modulus-article__comments-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--mod-gap-lg);
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-md);
  }

  .modulus-article__comment {
    padding-bottom: var(--mod-gap-md);
    border-bottom: 1px solid var(--color-border);
  }

  .modulus-article__comment-meta {
    display: flex;
    gap: 12px;
    align-items: baseline;
    margin-bottom: 8px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .modulus-article__comment-author {
    color: var(--color-foreground);
    font-weight: 500;
  }

  .modulus-article__comment-body {
    font-family: var(--font-body--family);
    font-size: 15px;
    color: var(--color-foreground);
    line-height: 1.65;
  }

  .modulus-article__comment-body p { margin: 0 0 0.6em; }
  .modulus-article__comment-body p:last-child { margin-bottom: 0; }

  .modulus-article__comment-form {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
    padding-top: var(--mod-gap-md);
    border-top: 1px solid var(--color-border);
  }

  h3.modulus-article__form-heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 20px;
    color: var(--color-foreground-heading, var(--color-foreground));
    margin: 0;
  }

  .modulus-article__form-note {
    font-family: var(--font-body--family);
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    margin: 0;
  }

  .modulus-article__form-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modulus-article__form-row label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-article__form-row input,
  .modulus-article__form-row textarea {
    font-family: var(--font-body--family);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: transparent;
    color: var(--color-foreground);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .modulus-article__form-row input:focus,
  .modulus-article__form-row textarea:focus {
    border-color: var(--color-foreground);
  }

  .modulus-article__form-errors,
  .modulus-article__form-success {
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    font-family: var(--font-body--family);
    font-size: 13px;
    line-height: 1.5;
  }

  .modulus-article__form-errors ul {
    margin: 6px 0 0;
    padding-left: 18px;
  }

  .modulus-article__form-errors { color: var(--color-foreground); }
  .modulus-article__form-success { color: var(--color-foreground); }

  /* ---- prev/next ---- */

  .modulus-article__adjacent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: var(--mod-gap-xl);
    padding-top: var(--mod-gap-md);
    border-top: 1px solid var(--color-border);
  }

  .modulus-article__adjacent-link {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: var(--color-foreground);
    padding: 24px;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .modulus-article__adjacent-link:hover {
    border-color: var(--color-foreground);
    background: rgb(var(--color-foreground-rgb) / 0.02);
  }

  .modulus-article__adjacent-link--next {
    text-align: right;
  }

  .modulus-article__adjacent-link--next .modulus-article__adjacent-label {
    justify-content: flex-end;
  }

  .modulus-article__adjacent-link--prev {
    grid-column: 1;
  }

  .modulus-article__adjacent-link--next {
    grid-column: 2;
  }

  .modulus-article__adjacent-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  .modulus-article__adjacent-title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 16px;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  /* ---- responsive ---- */

  @media (max-width: 1024px) {
    .modulus-article__body-wrap {
      grid-template-columns: 1fr;
    }
    .modulus-article__body,
    .modulus-article__share {
      grid-column: 1;
    }
  }

  @media (max-width: 640px) {
    .modulus-article__header { margin-bottom: var(--mod-gap-lg); }
    .modulus-article__hero { margin-bottom: var(--mod-gap-lg); }
    .modulus-article__adjacent { grid-template-columns: 1fr; }
    .modulus-article__adjacent-link--next { grid-column: 1; text-align: left; }
    .modulus-article__adjacent-link--next .modulus-article__adjacent-label { justify-content: flex-start; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Article",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Display" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "checkbox", "id": "show_featured_image", "label": "Show featured image", "default": true },
    { "type": "checkbox", "id": "hero_full_bleed", "label": "Featured image full bleed", "default": false },
    { "type": "checkbox", "id": "show_share", "label": "Show share links", "default": true },
    { "type": "checkbox", "id": "show_prev_next", "label": "Show previous / next article", "default": true },
