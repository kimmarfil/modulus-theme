{% comment %}
  Modulus Password — pre-launch / password-protected store landing.
  Editorial cover image on one side, launch message + newsletter signup
  + staff password entry on the other.
{% endcomment %}

<div
  id="modulus-password-{{ section.id }}"
  class="modulus-password color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--mpw-py: {{ section.settings.padding_y }}px;"
>
  <div class="modulus-password__inner">
    <div class="modulus-password__grid">

      {%- if section.settings.cover_image != blank -%}
        <figure class="modulus-password__cover" data-mod-reveal>
          <img
            src="{{ section.settings.cover_image | image_url: width: 1600 }}"
            srcset="
              {{ section.settings.cover_image | image_url: width: 800 }} 800w,
              {{ section.settings.cover_image | image_url: width: 1200 }} 1200w,
              {{ section.settings.cover_image | image_url: width: 1600 }} 1600w
            "
            sizes="(min-width: 1024px) 50vw, 100vw"
            alt="{{ section.settings.cover_image.alt | default: shop.name | escape }}"
            loading="eager"
            fetchpriority="high"
            width="{{ section.settings.cover_image.width }}"
            height="{{ section.settings.cover_image.height }}"
          >
        </figure>
      {%- endif -%}

      <div class="modulus-password__content{% unless section.settings.cover_image %} modulus-password__content--full{% endunless %}">
        <div class="modulus-password__content-inner" data-mod-reveal data-mod-reveal-delay="120">

          <a href="{{ routes.root_url }}" class="modulus-password__logo" aria-label="{{ shop.name | escape }}">
            {%- if section.settings.logo != blank -%}
              <img
                src="{{ section.settings.logo | image_url: width: 360 }}"
                alt="{{ shop.name | escape }}"
                width="{{ section.settings.logo.width }}"
                height="{{ section.settings.logo.height }}"
                style="max-height: {{ section.settings.logo_height | default: 40 }}px;"
              >
            {%- else -%}
              <span class="modulus-password__logo-text">{{ shop.name | escape }}</span>
            {%- endif -%}
          </a>

          {%- if section.settings.label_text != blank -%}
            {% render 'modulus-section-label',
              text: section.settings.label_text,
              number: section.settings.label_number
            %}
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h1 class="modulus-password__heading">{{ section.settings.heading }}</h1>
          {%- endif -%}

          {%- assign body = section.settings.body -%}
          {%- if body == blank and shop.password_message != blank -%}
            {%- assign body = shop.password_message -%}
          {%- endif -%}
          {%- if body != blank -%}
            <div class="modulus-password__body">{{ body }}</div>
          {%- endif -%}

          {%- if section.settings.show_newsletter -%}
            <div class="modulus-password__newsletter">
              <span class="modulus-password__newsletter-label">
                {{ section.settings.newsletter_label | default: 'Get notified when we launch' }}
              </span>

              {% form 'customer', id: 'modulus-password-newsletter' %}
                <input type="hidden" name="contact[tags]" value="newsletter,password-page">

                {%- if form.posted_successfully? -%}
                  <div class="modulus-password__notice modulus-password__notice--success" role="status">
                    {{ section.settings.newsletter_success | default: "Thanks — we'll be in touch." }}
                  </div>
                {%- elsif form.errors -%}
                  <div class="modulus-password__notice modulus-password__notice--error" role="alert">
                    {{ form.errors | default_errors }}
                  </div>
                {%- endif -%}

                <div class="modulus-password__newsletter-field">
                  <label for="modulus-newsletter-email-{{ section.id }}" class="visually-hidden">Email</label>
                  <input
                    type="email"
                    id="modulus-newsletter-email-{{ section.id }}"
                    name="contact[email]"
                    placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email' | escape }}"
                    autocomplete="email"
                    required
                  >
                  <button type="submit" class="modulus-password__newsletter-submit" aria-label="Subscribe">
                    {% render 'modulus-icon', name: 'arrow-right', size: 14 %}
                  </button>
                </div>
              {% endform %}
            </div>
          {%- endif -%}

          {%- if section.settings.show_social -%}
            <ul class="modulus-password__social" role="list">
              {%- if shop.metafields.social.instagram_url != blank or settings.social_instagram_link != blank -%}
                <li><a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener">Instagram</a></li>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <li><a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener">Twitter</a></li>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <li><a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener">Facebook</a></li>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <li><a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener">TikTok</a></li>
              {%- endif -%}
            </ul>
          {%- endif -%}

          <details class="modulus-password__staff">
            <summary class="modulus-password__staff-toggle">
              <span>{{ section.settings.staff_label | default: 'Staff entry' }}</span>
              {% render 'modulus-icon', name: 'chevron-down', size: 12 %}
            </summary>
            <div class="modulus-password__staff-panel">
              {% form 'storefront_password', class: 'modulus-password__staff-form' %}
                {%- if form.errors -%}
                  <div class="modulus-password__notice modulus-password__notice--error" role="alert">
                    {{ section.settings.password_error | default: 'Incorrect password — try again.' }}
                  </div>
                {%- endif -%}
                <div class="modulus-password__staff-field">
                  <label for="modulus-password-input-{{ section.id }}" class="visually-hidden">Password</label>
                  <input
                    type="password"
                    id="modulus-password-input-{{ section.id }}"
                    name="password"
                    placeholder="Password"
                    autocomplete="current-password"
                    required
                  >
                  <button type="submit" class="modulus-password__staff-submit">Enter</button>
                </div>
              {% endform %}
            </div>
          </details>
        </div>

        <footer class="modulus-password__footer">
          <span class="modulus-password__copyright">
            © {{ 'now' | date: '%Y' }} {{ shop.name | escape }}
          </span>
          <a href="https://www.shopify.com" target="_blank" rel="noopener" class="modulus-password__powered">
            Powered by Shopify
          </a>
        </footer>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .modulus-password {
    display: block;
    background: var(--color-background);
    color: var(--color-foreground);
    min-height: 100vh;
  }

  .modulus-password__inner {
    min-height: 100vh;
  }

  .modulus-password__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .modulus-password__cover {
    margin: 0;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .modulus-password__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modulus-password__content {
    display: flex;
    flex-direction: column;
    padding: clamp(32px, 6vw, 80px);
    min-height: 100vh;
  }

  .modulus-password__content--full {
    grid-column: 1 / -1;
    max-width: 720px;
    margin: 0 auto;
  }

  .modulus-password__content-inner {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-md);
    max-width: 480px;
    margin: auto 0;
  }

  /* ---- logo ---- */

  .modulus-password__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-foreground);
    margin-bottom: var(--mod-gap-sm);
  }

  .modulus-password__logo img {
    display: block;
    height: auto;
    width: auto;
    max-width: 240px;
  }

  .modulus-password__logo-text {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 18px;
    letter-spacing: 0.01em;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  /* ---- heading + body ---- */

  h1.modulus-password__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(32px, 5vw, 56px);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .modulus-password__body {
    font-family: var(--font-body--family);
    font-size: clamp(15px, 1.1vw, 17px);
    color: rgb(var(--color-foreground-rgb) / 0.8);
    line-height: 1.65;
  }

  .modulus-password__body p { margin: 0 0 0.8em; }
  .modulus-password__body p:last-child { margin-bottom: 0; }

  /* ---- newsletter ---- */

  .modulus-password__newsletter {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: var(--mod-gap-sm);
    border-top: 1px solid var(--color-border);
  }

  .modulus-password__newsletter-label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-password__newsletter-field {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--color-foreground);
  }

  .modulus-password__newsletter-field input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    font-family: var(--font-body--family);
    font-size: 16px;
    color: var(--color-foreground);
    padding: 12px 0;
    outline: none;
  }

  .modulus-password__newsletter-field input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.45);
  }

  .modulus-password__newsletter-submit {
    background: transparent;
    border: none;
    padding: 0 14px;
    cursor: pointer;
    color: var(--color-foreground);
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .modulus-password__newsletter-submit:hover {
    transform: translateX(2px);
  }

  /* ---- notices ---- */

  .modulus-password__notice {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    font-family: var(--font-body--family);
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 4px;
  }

  .modulus-password__notice--success { color: var(--color-foreground); }
  .modulus-password__notice--error { color: var(--color-foreground); border-color: var(--color-foreground); }

  /* ---- social ---- */

  .modulus-password__social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .modulus-password__social a {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.2s ease;
  }

  .modulus-password__social a:hover {
    border-bottom-color: var(--color-foreground);
  }

  /* ---- staff entry ---- */

  .modulus-password__staff {
    margin-top: var(--mod-gap-sm);
  }

  .modulus-password__staff-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    list-style: none;
    transition: color 0.2s ease;
  }

  .modulus-password__staff-toggle::-webkit-details-marker { display: none; }
  .modulus-password__staff-toggle::marker { content: ''; }
  .modulus-password__staff-toggle:hover { color: var(--color-foreground); }

  .modulus-password__staff[open] .modulus-password__staff-toggle {
    color: var(--color-foreground);
  }

  .modulus-password__staff-panel {
    margin-top: 12px;
  }

  .modulus-password__staff-field {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-border);
  }

  .modulus-password__staff-field input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
    padding: 10px 14px;
    outline: none;
  }

  .modulus-password__staff-submit {
    background: var(--color-foreground);
    color: var(--color-background);
    border: none;
    padding: 10px 20px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .modulus-password__staff-submit:hover {
    opacity: 0.85;
  }

  /* ---- footer ---- */

  .modulus-password__footer {
    margin-top: var(--mod-gap-lg);
    padding-top: var(--mod-gap-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .modulus-password__footer a {
    color: inherit;
    text-decoration: none;
  }

  .modulus-password__footer a:hover {
    color: var(--color-foreground);
  }

  /* ---- visually hidden ---- */

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---- responsive ---- */

  @media (max-width: 1024px) {
    .modulus-password__grid {
      grid-template-columns: 1fr;
    }
    .modulus-password__cover {
      aspect-ratio: 16 / 9;
      height: auto;
    }
    .modulus-password__content { min-height: auto; padding: 40px 28px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Password",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Branding" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo max height",
      "min": 20, "max": 96, "step": 2, "unit": "px",
      "default": 40
    },
    { "type": "image_picker", "id": "cover_image", "label": "Cover image" },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "label_text", "label": "Section label", "default": "Coming soon" },
    { "type": "text", "id": "label_number", "label": "Section number", "default": "01" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "info": "Leave blank to use the storefront password message from Shopify admin → Preferences.",
      "default": "<p>We're putting the finishing touches on our store. Leave your email and we'll let you know the moment we open.</p>"
    },

    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Show email signup", "default": true },
    { "type": "text", "id": "newsletter_label", "label": "Newsletter label", "default": "Get notified when we launch" },
    { "type": "text", "id": "newsletter_placeholder", "label": "Newsletter placeholder", "default": "Your email" },
    { "type": "text", "id": "newsletter_success", "label": "Newsletter success message", "default": "Thanks — we'll be in touch." },

    { "type": "header", "content": "Staff entry" },
    { "type": "text", "id": "staff_label", "label": "Staff entry toggle label", "default": "Staff entry" },
    { "type": "text", "id": "password_error", "label": "Password error message", "default": "Incorrect password — try again." },

    { "type": "header", "content": "Social" },
    { "type": "checkbox", "id": "show_social", "label": "Show social links", "info": "Uses links from theme settings.", "default": true },

    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full", "label": "Full viewport" }
      ],
      "default": "full"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 0, "max": 240, "step": 4, "unit": "px",
      "default": 0
    },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [{ "name": "Modulus Password" }],
  "enabled_on": {
    "templates": ["password"]
  }
}
{% endschema %}
