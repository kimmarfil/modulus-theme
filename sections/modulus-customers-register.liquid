{% comment %}
  Modulus Customers · Register — create a new account.
  Shares the .modulus-cust auth styling. Self-contained copy so the
  section ships without a shared stylesheet dependency.
{% endcomment %}

<div
  id="modulus-cust-register-{{ section.id }}"
  class="modulus-cust modulus-cust--auth color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--mc-py: {{ section.settings.padding_y }}px;"
>
  <div class="modulus-cust__inner modulus-cust__inner--auth">
    <div class="modulus-cust__panel" data-mod-reveal>
      <header class="modulus-cust__header">
        <h1 class="modulus-cust__heading">{{ section.settings.heading | default: 'Create account' }}</h1>
        {%- if section.settings.subtitle != blank -%}
          <p class="modulus-cust__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </header>

      {% form 'create_customer', novalidate: 'novalidate' %}
        {%- if form.errors -%}
          <div class="modulus-cust__notice modulus-cust__notice--error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="modulus-cust__field-row">
          <div class="modulus-cust__field">
            <label for="cust-reg-first-{{ section.id }}">First name</label>
            <input type="text" id="cust-reg-first-{{ section.id }}" name="customer[first_name]" autocomplete="given-name" value="{% if form.first_name %}{{ form.first_name }}{% endif %}" required>
          </div>
          <div class="modulus-cust__field">
            <label for="cust-reg-last-{{ section.id }}">Last name</label>
            <input type="text" id="cust-reg-last-{{ section.id }}" name="customer[last_name]" autocomplete="family-name" value="{% if form.last_name %}{{ form.last_name }}{% endif %}" required>
          </div>
        </div>

        <div class="modulus-cust__field">
          <label for="cust-reg-email-{{ section.id }}">Email</label>
          <input type="email" id="cust-reg-email-{{ section.id }}" name="customer[email]" autocomplete="email" value="{% if form.email %}{{ form.email }}{% endif %}" required>
        </div>

        <div class="modulus-cust__field">
          <label for="cust-reg-password-{{ section.id }}">Password</label>
          <input type="password" id="cust-reg-password-{{ section.id }}" name="customer[password]" autocomplete="new-password" required>
        </div>

        <button type="submit" class="mod-btn mod-btn--primary modulus-cust__submit">
          <span>{{ section.settings.submit_label | default: 'Create account' }}</span>
          <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
        </button>
      {% endform %}

      <div class="modulus-cust__extra">
        <p class="modulus-cust__alt-cta">
          {{ section.settings.login_prompt | default: 'Already have an account?' }}
          <a href="{{ routes.account_login_url }}">{{ section.settings.login_cta | default: 'Sign in' }}</a>
        </p>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .modulus-cust {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--mc-py, var(--mod-section-py)) var(--mod-section-px);
  }

  .modulus-cust__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  .modulus-cust__inner--auth {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  .modulus-cust__panel {
    width: 100%;
    max-width: 520px;
    border: 1px solid var(--color-border);
    padding: clamp(28px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
  }

  .modulus-cust__header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: var(--mod-gap-sm);
  }

  h1.modulus-cust__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(26px, 3.4vw, 40px);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .modulus-cust__subtitle {
    font-family: var(--font-body--family);
    font-size: 14px;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    line-height: 1.55;
    margin: 0;
  }

  .modulus-cust__field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .modulus-cust__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: var(--mod-gap-sm);
  }

  .modulus-cust__field label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-cust__field input,
  .modulus-cust__field select,
  .modulus-cust__field textarea {
    font-family: var(--font-body--family);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: transparent;
    color: var(--color-foreground);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .modulus-cust__field input:focus,
  .modulus-cust__field select:focus,
  .modulus-cust__field textarea:focus {
    border-color: var(--color-foreground);
  }

  .modulus-cust__submit {
    align-self: flex-start;
    justify-content: center;
  }

  .modulus-cust__notice {
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    font-family: var(--font-body--family);
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: var(--mod-gap-sm);
  }

  .modulus-cust__notice--error { border-color: var(--color-foreground); }

  .modulus-cust__extra {
    margin-top: var(--mod-gap-sm);
    padding-top: var(--mod-gap-sm);
    border-top: 1px solid var(--color-border);
  }

  .modulus-cust__alt-cta {
    font-family: var(--font-body--family);
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    margin: 0;
  }

  .modulus-cust__alt-cta a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 480px) {
    .modulus-cust__field-row { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Register",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Create account" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Join us — it takes a minute." },
    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Create account" },

    { "type": "header", "content": "Login prompt" },
    { "type": "text", "id": "login_prompt", "label": "Login prompt", "default": "Already have an account?" },
    { "type": "text", "id": "login_cta", "label": "Login CTA", "default": "Sign in" },

    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full", "label": "Full viewport" }
      ],
      "default": "full"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40, "max": 240, "step": 4, "unit": "px",
      "default": 96
    },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [{ "name": "Modulus Register" }],
  "enabled_on": {
    "templates": ["customers/register"]
  }
}
{% endschema %}
