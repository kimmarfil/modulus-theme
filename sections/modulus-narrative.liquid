{% comment %}
  Modulus Narrative — large chapter-opener heading with body text
  right-aligned below. Editorial long-form intro.
{% endcomment %}

<div
  id="modulus-narrative-{{ section.id }}"
  class="modulus-narrative color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="
    --narr-heading-size: {{ section.settings.heading_size }}px;
    --narr-heading-width: {{ section.settings.heading_width }}%;
    --narr-py: {{ section.settings.padding_y }}px;
  "
>
  <div class="modulus-narrative__inner">
    {%- if section.settings.label_text != blank -%}
      <div data-mod-reveal>
        {% render 'modulus-section-label',
          text: section.settings.label_text,
          number: section.settings.label_number
        %}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="modulus-narrative__heading" data-mod-reveal>
        {{ section.settings.heading }}
      </{{ section.settings.heading_tag }}>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <div class="modulus-narrative__body-wrap" data-mod-reveal data-mod-reveal-delay="120">
        <div class="modulus-narrative__body">
          {{ section.settings.body_text }}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <div class="modulus-narrative__cta" data-mod-reveal data-mod-reveal-delay="200">
        <a href="{{ section.settings.button_link | default: '#' }}" class="mod-btn mod-btn--ghost-dark">
          <span>{{ section.settings.button_label }}</span>
          <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .modulus-narrative {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--narr-py, var(--mod-section-py)) var(--mod-section-px);
  }

  .modulus-narrative__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  .modulus-narrative__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--narr-heading-size, clamp(40px, 6vw, 72px));
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 0 0 var(--mod-gap-xl);
    max-width: var(--narr-heading-width, 70%);
  }

  .modulus-narrative__heading p {
    margin: 0;
  }

  .modulus-narrative__body-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .modulus-narrative__body {
    font-family: var(--font-body--family);
    font-size: clamp(15px, 1.1vw, 17px);
    color: rgb(var(--color-foreground-rgb) / 0.75);
    line-height: 1.75;
    max-width: 480px;
  }

  .modulus-narrative__body p {
    margin: 0 0 1em;
  }

  .modulus-narrative__body p:last-child {
    margin-bottom: 0;
  }

  .modulus-narrative__cta {
    display: flex;
    justify-content: flex-end;
    margin-top: var(--mod-gap-md);
  }

  @media (max-width: 1024px) {
    .modulus-narrative__heading {
      max-width: 85%;
    }
  }

  @media (max-width: 768px) {
    .modulus-narrative__heading {
      font-size: clamp(28px, 8vw, 44px);
      max-width: 100%;
      margin-bottom: var(--mod-gap-lg);
    }
    .modulus-narrative__body-wrap,
    .modulus-narrative__cta {
      justify-content: flex-start;
    }
    .modulus-narrative__body {
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Narrative",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "label_text", "label": "Section label" },
    { "type": "text", "id": "label_number", "label": "Section number" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>A statement bold enough to carry a page on its own.</p>"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text (right-aligned)",
      "default": "<p>A short supporting paragraph that expands on the heading without repeating it. Keep it to two or three sentences.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full", "label": "Full viewport" }
      ],
      "default": "full"
    },
    { "type": "header", "content": "Typography" },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop)",
      "min": 32, "max": 120, "step": 4, "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "heading_width",
      "label": "Heading max width (%)",
      "min": 50, "max": 100, "step": 5, "unit": "%",
      "default": 70
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40, "max": 240, "step": 4, "unit": "px",
      "default": 120
    },
    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [{ "name": "Modulus Narrative" }],
  "enabled_on": {
    "templates": ["index", "page", "product", "collection", "article", "blog"]
  }
}
{% endschema %}
