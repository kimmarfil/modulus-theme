    { "type": "text", "id": "continue_label", "label": "Continue shopping label", "default": "Continue shopping" },
    { "type": "text", "id": "update_label", "label": "Update cart label", "default": "Update cart" },
    { "type": "text", "id": "summary_heading", "label": "Summary heading", "default": "Summary" },
    { "type": "text", "id": "summary_note", "label": "Summary note", "default": "Taxes and shipping calculated at checkout." },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "Checkout" },

    { "type": "header", "content": "Order notes" },
