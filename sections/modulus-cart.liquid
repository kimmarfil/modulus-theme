{
  "name": "Modulus Cart",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "label_text", "label": "Section label", "default": "Cart" },
    { "type": "text", "id": "label_number", "label": "Section number", "default": "01" },
