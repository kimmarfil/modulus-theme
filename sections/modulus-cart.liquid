{% comment %}
  Modulus Cart — full cart page.
  Editorial line-item layout with qty stepper, inline remove, cart note,
  discounts, and sticky summary. Works without JS via native {% form 'cart' %};
  JS enhances with auto-update on quantity change and AJAX remove.
{% endcomment %}

<modulus-cart
  id="modulus-cart-{{ section.id }}"
  class="modulus-cart color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--mc-py: {{ section.settings.padding_y }}px;"
>
  <div class="modulus-cart__inner">
    <header class="modulus-cart__head" data-mod-reveal>
      {%- if section.settings.label_text != blank -%}
        {% render 'modulus-section-label',
          text: section.settings.label_text,
          number: section.settings.label_number
        %}
      {%- endif -%}
      <h1 class="modulus-cart__heading">
        {%- if cart.item_count > 0 -%}
          {{ section.settings.heading | default: 'Your cart' }}
          <span class="modulus-cart__count">({{ cart.item_count }})</span>
        {%- else -%}
          {{ section.settings.empty_heading | default: 'Your cart is empty' }}
        {%- endif -%}
      </h1>
    </header>

    {%- if cart.item_count == 0 -%}
      <div class="modulus-cart__empty" data-mod-reveal>
        {%- if section.settings.empty_text != blank -%}
          <p class="modulus-cart__empty-text">{{ section.settings.empty_text }}</p>
        {%- endif -%}
        <a href="{{ routes.all_products_collection_url }}" class="mod-btn mod-btn--primary">
          <span>{{ section.settings.empty_cta_label | default: 'Continue shopping' }}</span>
          <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
        </a>
      </div>
    {%- else -%}
      <form
        action="{{ routes.cart_url }}"
        method="post"
        id="modulus-cart-form-{{ section.id }}"
        class="modulus-cart__form"
        data-mod-cart-form
      >
        {% render 'modulus-free-shipping-bar', context: 'cart' %}

        <div class="modulus-cart__layout">

          {%- comment -%} ===== LINE ITEMS ===== {%- endcomment -%}
          <section class="modulus-cart__items" aria-label="Cart items">
            <div class="modulus-cart__items-head">
              <span class="modulus-cart__col-head modulus-cart__col-head--product">Product</span>
              <span class="modulus-cart__col-head modulus-cart__col-head--price">Price</span>
              <span class="modulus-cart__col-head modulus-cart__col-head--qty">Quantity</span>
              <span class="modulus-cart__col-head modulus-cart__col-head--total">Total</span>
            </div>

            <ul class="modulus-cart__lines" role="list" data-mod-cart-lines>
              {%- for item in cart.items -%}
                <li class="modulus-cart__line" data-mod-cart-line data-key="{{ item.key }}" data-mod-reveal data-mod-reveal-delay="{{ forloop.index0 | times: 60 }}">
                  <div class="modulus-cart__line-product">
                    <a href="{{ item.url }}" class="modulus-cart__line-image-link" tabindex="-1" aria-hidden="true">
                      {%- if item.image != blank -%}
                        <img
                          class="modulus-cart__line-image"
                          src="{{ item.image | image_url: width: 240 }}"
                          srcset="
                            {{ item.image | image_url: width: 160 }} 160w,
                            {{ item.image | image_url: width: 240 }} 240w,
                            {{ item.image | image_url: width: 360 }} 360w
                          "
                          sizes="120px"
                          alt="{{ item.image.alt | default: item.product.title | escape }}"
                          loading="lazy"
                          width="{{ item.image.width }}"
                          height="{{ item.image.height }}"
                        >
                      {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag: 'modulus-cart__line-image' }}
                      {%- endif -%}
                    </a>

                    <div class="modulus-cart__line-info">
                      <a href="{{ item.url }}" class="modulus-cart__line-title">{{ item.product.title | escape }}</a>

                      {%- unless item.product_has_only_default_variant -%}
                        <span class="modulus-cart__line-variant">{{ item.variant.title | escape }}</span>
                      {%- endunless -%}

                      {%- if item.selling_plan_allocation != blank -%}
                        <span class="modulus-cart__line-variant">{{ item.selling_plan_allocation.selling_plan.name | escape }}</span>
                      {%- endif -%}

                      {%- if item.properties != blank -%}
                        <ul class="modulus-cart__line-properties" role="list">
                          {%- for property in item.properties -%}
                            {%- assign first_char = property.first | slice: 0 -%}
                            {%- if property.last != blank and first_char != '_' -%}
                              <li>
                                <span class="modulus-cart__line-property-name">{{ property.first | escape }}:</span>
                                {%- if property.last contains '/uploads/' -%}
                                  <a href="{{ property.last }}" target="_blank" rel="noopener">{{ property.last | split: '/' | last | escape }}</a>
                                {%- else -%}
                                  <span>{{ property.last | escape }}</span>
                                {%- endif -%}
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                      {%- if item.line_level_discount_allocations.size > 0 -%}
                        <ul class="modulus-cart__line-discounts" role="list">
                          {%- for allocation in item.line_level_discount_allocations -%}
                            <li class="modulus-cart__line-discount">
                              <span>{{ allocation.discount_application.title | escape }}</span>
                              <span>−{{ allocation.amount | money }}</span>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                      <button
                        type="button"
                        class="modulus-cart__line-remove"
                        data-mod-cart-remove
                        data-key="{{ item.key }}"
                        aria-label="Remove {{ item.product.title | escape }}"
                      >
                        {% render 'modulus-icon', name: 'close', size: 12 %}
                        <span>Remove</span>
                      </button>
                    </div>
                  </div>

                  <div class="modulus-cart__line-price">
                    {%- if item.original_price != item.final_price -%}
                      <span class="modulus-cart__price modulus-cart__price--compare"><s>{{ item.original_price | money }}</s></span>
                      <span class="modulus-cart__price modulus-cart__price--sale">{{ item.final_price | money }}</span>
                    {%- else -%}
                      <span class="modulus-cart__price">{{ item.final_price | money }}</span>
                    {%- endif -%}
                    {%- if item.unit_price_measurement -%}
                      <span class="modulus-cart__unit-price">
                        {{ item.unit_price | money }}/{{ item.unit_price_measurement.reference_value }}{{ item.unit_price_measurement.reference_unit }}
                      </span>
                    {%- endif -%}
                  </div>

                  <div class="modulus-cart__line-qty">
                    <div class="modulus-cart__qty-stepper" data-mod-cart-stepper>
                      <button type="button" class="modulus-cart__qty-btn" data-mod-qty-dec aria-label="Decrease quantity">
                        {% render 'modulus-icon', name: 'minus', size: 12 %}
                      </button>
                      <input
                        type="number"
                        class="modulus-cart__qty-input"
                        name="updates[{{ item.key }}]"
                        value="{{ item.quantity }}"
                        min="0"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        data-mod-qty-input
                        data-key="{{ item.key }}"
                        aria-label="Quantity for {{ item.product.title | escape }}"
                      >
                      <button type="button" class="modulus-cart__qty-btn" data-mod-qty-inc aria-label="Increase quantity">
                        {% render 'modulus-icon', name: 'plus', size: 12 %}
                      </button>
                    </div>
                  </div>

                  <div class="modulus-cart__line-total">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <span class="modulus-cart__price modulus-cart__price--compare"><s>{{ item.original_line_price | money }}</s></span>
                      <span class="modulus-cart__price modulus-cart__price--sale">{{ item.final_line_price | money }}</span>
                    {%- else -%}
                      <span class="modulus-cart__price">{{ item.final_line_price | money }}</span>
                    {%- endif -%}
                  </div>
                </li>
              {%- endfor -%}
            </ul>

            {%- if section.settings.show_note -%}
              <div class="modulus-cart__note">
                <label for="cart-note-{{ section.id }}" class="modulus-cart__note-label">
                  {{ section.settings.note_label | default: 'Order notes' }}
                </label>
                <textarea
                  id="cart-note-{{ section.id }}"
                  name="note"
                  rows="3"
                  class="modulus-cart__note-input"
                  placeholder="{{ section.settings.note_placeholder | default: 'Add special instructions for your order…' | escape }}"
                >{{ cart.note }}</textarea>
              </div>
            {%- endif -%}

            <div class="modulus-cart__update-row">
              <a href="{{ routes.all_products_collection_url }}" class="modulus-cart__continue">
                {% render 'modulus-icon', name: 'arrow-left', size: 12 %}
                <span>{{ section.settings.continue_label | default: 'Continue shopping' }}</span>
              </a>
              <button type="submit" name="update" class="modulus-cart__update-btn">
                {{ section.settings.update_label | default: 'Update cart' }}
              </button>
            </div>
          </section>

          {%- comment -%} ===== SUMMARY ===== {%- endcomment -%}
          <aside class="modulus-cart__summary" aria-label="Cart summary">
            <div class="modulus-cart__summary-inner" data-mod-reveal data-mod-reveal-delay="120">
              <h2 class="modulus-cart__summary-heading">
                {{ section.settings.summary_heading | default: 'Summary' }}
              </h2>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <ul class="modulus-cart__summary-discounts" role="list">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <li class="modulus-cart__summary-row modulus-cart__summary-row--discount">
                      <span>{{ discount.title | escape }}</span>
                      <span>−{{ discount.total_allocated_amount | money }}</span>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              <div class="modulus-cart__summary-row modulus-cart__summary-row--subtotal">
                <span class="modulus-cart__summary-label">Subtotal</span>
                <span class="modulus-cart__summary-value" data-mod-cart-total>{{ cart.total_price | money }}</span>
              </div>

              <p class="modulus-cart__summary-note">
                {{ section.settings.summary_note | default: 'Taxes and shipping calculated at checkout.' }}
              </p>

              <button
                type="submit"
                name="checkout"
                class="modulus-cart__checkout mod-btn mod-btn--primary"
                {% if cart.item_count == 0 %}disabled{% endif %}
              >
                <span>{{ section.settings.checkout_label | default: 'Checkout' }}</span>
                <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
              </button>

              {%- if additional_checkout_buttons -%}
                <div class="modulus-cart__additional-checkout">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
            </div>
          </aside>
        </div>
      </form>
    {%- endif -%}
  </div>
</modulus-cart>

{% stylesheet %}
  .modulus-cart {
    display: block;
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--mc-py, var(--mod-section-py)) var(--mod-section-px);
  }

  .modulus-cart__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  .modulus-cart__head {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
    margin-bottom: var(--mod-gap-xl);
    padding-bottom: var(--mod-gap-md);
    border-bottom: 1px solid var(--color-border);
  }

  h1.modulus-cart__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(32px, 5vw, 64px);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .modulus-cart__count {
    font-weight: 400;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin-left: 8px;
  }

  /* ---- empty state ---- */

  .modulus-cart__empty {
    padding: var(--mod-gap-xl) 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--mod-gap-md);
  }

  .modulus-cart__empty-text {
    font-family: var(--font-body--family);
    font-size: clamp(15px, 1.1vw, 17px);
    color: rgb(var(--color-foreground-rgb) / 0.75);
    line-height: 1.7;
    max-width: 520px;
    margin: 0;
  }

  /* ---- layout ---- */

  .modulus-cart__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: var(--mod-gap-xl);
    align-items: start;
  }

  /* ---- items list ---- */

  .modulus-cart__items-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 120px 140px 120px;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .modulus-cart__col-head {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .modulus-cart__col-head--price,
  .modulus-cart__col-head--qty {
    text-align: left;
  }

  .modulus-cart__col-head--total {
    text-align: right;
  }

  .modulus-cart__lines {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .modulus-cart__line {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 120px 140px 120px;
    gap: 16px;
    align-items: start;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .modulus-cart__line-product {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 20px;
    align-items: start;
    min-width: 0;
  }

  .modulus-cart__line-image-link {
    display: block;
    width: 120px;
    aspect-ratio: 1;
    background: rgb(var(--color-foreground-rgb) / 0.05);
    overflow: hidden;
  }

  .modulus-cart__line-image,
  .modulus-cart__line-image-link svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modulus-cart__line-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .modulus-cart__line-title {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: clamp(15px, 1.2vw, 18px);
    color: var(--color-foreground-heading, var(--color-foreground));
    text-decoration: none;
    line-height: 1.3;
  }

  .modulus-cart__line-title:hover {
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-cart__line-variant {
    font-family: var(--font-body--family);
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    line-height: 1.4;
  }

  .modulus-cart__line-properties {
    list-style: none;
    padding: 0;
    margin: 2px 0 0;
    font-family: var(--font-body--family);
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    line-height: 1.5;
  }

  .modulus-cart__line-property-name {
    font-weight: 500;
    margin-right: 4px;
  }

  .modulus-cart__line-discounts {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
  }

  .modulus-cart__line-discount {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    max-width: 260px;
  }

  .modulus-cart__line-remove {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: none;
    padding: 4px 0;
    margin-top: 6px;
    cursor: pointer;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    align-self: flex-start;
    transition: color 0.2s ease;
  }

  .modulus-cart__line-remove:hover {
    color: var(--color-foreground);
  }

  .modulus-cart__line-price,
  .modulus-cart__line-total {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
    padding-top: 2px;
  }

  .modulus-cart__line-total {
    align-items: flex-end;
    text-align: right;
  }

  .modulus-cart__price--compare {
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font-size: 12px;
  }

  .modulus-cart__price--sale {
    color: var(--color-foreground);
  }

  .modulus-cart__unit-price {
    font-size: 11px;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    letter-spacing: 0.02em;
  }

  /* ---- quantity stepper ---- */

  .modulus-cart__qty-stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
    width: fit-content;
  }

  .modulus-cart__qty-btn {
    width: 36px;
    height: 36px;
    background: transparent;
    border: none;
    color: var(--color-foreground);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .modulus-cart__qty-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .modulus-cart__qty-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    background: transparent;
    color: var(--color-foreground);
  }

  .modulus-cart__qty-input {
    width: 48px;
    height: 36px;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    background: transparent;
    text-align: center;
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
    appearance: textfield;
    -moz-appearance: textfield;
  }

  .modulus-cart__qty-input::-webkit-inner-spin-button,
  .modulus-cart__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .modulus-cart__qty-input:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: -2px;
  }

  /* ---- note + update row ---- */

  .modulus-cart__note {
    margin-top: var(--mod-gap-lg);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .modulus-cart__note-label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-cart__note-input {
    width: 100%;
    min-height: 96px;
    padding: 12px 14px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0;
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
    resize: vertical;
  }

  .modulus-cart__note-input:focus-visible {
    outline: none;
    border-color: var(--color-foreground);
  }

  .modulus-cart__update-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-top: var(--mod-gap-lg);
    flex-wrap: wrap;
  }

  .modulus-cart__continue {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
  }

  .modulus-cart__continue:hover {
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-cart__update-btn {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 12px 22px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .modulus-cart__update-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ---- summary ---- */

  .modulus-cart__summary {
    position: sticky;
    top: 100px;
  }

  .modulus-cart__summary-inner {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-md);
    padding: 28px;
    border: 1px solid var(--color-border);
    background: rgb(var(--color-foreground-rgb) / 0.02);
  }

  h2.modulus-cart__summary-heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 20px;
    letter-spacing: -0.005em;
    color: var(--color-foreground-heading, var(--color-foreground));
    margin: 0;
  }

  .modulus-cart__summary-discounts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modulus-cart__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    font-family: var(--font-body--family);
  }

  .modulus-cart__summary-row--discount {
    font-size: 13px;
    color: rgb(var(--color-foreground-rgb) / 0.8);
  }

  .modulus-cart__summary-row--subtotal {
    padding-top: var(--mod-gap-sm);
    border-top: 1px solid var(--color-border);
    font-size: 18px;
  }

  .modulus-cart__summary-label {
    font-weight: 500;
  }

  .modulus-cart__summary-value {
    font-weight: 500;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .modulus-cart__summary-note {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    line-height: 1.5;
    margin: 0;
  }

  .modulus-cart__checkout {
    width: 100%;
    justify-content: center;
    padding: 18px 24px;
  }

  .modulus-cart__checkout[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .modulus-cart__additional-checkout {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* ---- loading state ---- */

  .modulus-cart.is-loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .modulus-cart__line.is-removing {
    opacity: 0.35;
    transition: opacity 0.2s ease;
  }

  /* ---- responsive ---- */

  @media (max-width: 1024px) {
    .modulus-cart__layout {
      grid-template-columns: 1fr;
      gap: var(--mod-gap-lg);
    }
    .modulus-cart__summary {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .modulus-cart__items-head {
      display: none;
    }
    .modulus-cart__line {
      grid-template-columns: minmax(0, 1fr);
      gap: 14px;
      padding: 20px 0;
    }
    .modulus-cart__line-product {
      grid-template-columns: 88px minmax(0, 1fr);
      gap: 14px;
    }
    .modulus-cart__line-image-link {
      width: 88px;
    }
    .modulus-cart__line-price {
      display: none;
    }
    .modulus-cart__line-qty,
    .modulus-cart__line-total {
      padding-left: 102px;
    }
    .modulus-cart__line-total {
      text-align: left;
      align-items: flex-start;
      font-weight: 500;
    }
    .modulus-cart__update-row {
      justify-content: flex-start;
    }
    .modulus-cart__summary-inner {
      padding: 24px;
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('modulus-cart')) {
    customElements.define('modulus-cart', class ModulusCart extends HTMLElement {
      connectedCallback() {
        this.form = this.querySelector('[data-mod-cart-form]');
        this.totalEl = this.querySelector('[data-mod-cart-total]');
        this.bindSteppers();
        this.bindQtyChange();
        this.bindRemove();
      }

      bindSteppers() {
        this.querySelectorAll('[data-mod-cart-stepper]').forEach((stepper) => {
          const input = stepper.querySelector('[data-mod-qty-input]');
          const dec = stepper.querySelector('[data-mod-qty-dec]');
          const inc = stepper.querySelector('[data-mod-qty-inc]');
          if (!input) return;
          if (dec) dec.addEventListener('click', () => this.stepQty(input, -1));
          if (inc) inc.addEventListener('click', () => this.stepQty(input, 1));
        });
      }

      stepQty(input, delta) {
        const current = parseInt(input.value, 10) || 0;
        const next = Math.max(0, current + delta);
        if (next === current) return;
        input.value = next;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }

      bindQtyChange() {
        let debounce = null;
        this.querySelectorAll('[data-mod-qty-input]').forEach((input) => {
          input.addEventListener('change', () => {
            const key = input.dataset.key;
            const qty = Math.max(0, parseInt(input.value, 10) || 0);
            input.value = qty;
            clearTimeout(debounce);
            debounce = setTimeout(() => this.updateLine(key, qty), 180);
          });
        });
      }

      bindRemove() {
        this.querySelectorAll('[data-mod-cart-remove]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const key = btn.dataset.key;
            const line = btn.closest('[data-mod-cart-line]');
            if (line) line.classList.add('is-removing');
            this.updateLine(key, 0);
          });
        });
      }

      updateLine(key, qty) {
        this.classList.add('is-loading');
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ id: key, quantity: qty })
        })
          .then((r) => r.json())
          .then((cart) => {
            if (qty === 0) {
              window.location.reload();
              return;
            }
            if (this.totalEl && typeof cart.total_price === 'number') {
              this.totalEl.textContent = this.formatMoney(cart.total_price);
            }
            const line = this.querySelector(`[data-mod-cart-line][data-key="${CSS.escape(key)}"]`);
            const updated = (cart.items || []).find((i) => i.key === key);
            if (line && updated) {
              const totalEl = line.querySelector('.modulus-cart__line-total');
              if (totalEl) totalEl.innerHTML = `<span class="modulus-cart__price">${this.formatMoney(updated.final_line_price)}</span>`;
            }
            this.updateShippingBar(cart);
            window.dispatchEvent(new CustomEvent('modulus:cart:update', { detail: cart }));
          })
          .catch(() => {
            window.location.reload();
          })
          .finally(() => {
            this.classList.remove('is-loading');
          });
      }

      updateShippingBar(cart) {
        const bar = this.querySelector('[data-mod-ship-bar]');
        if (!bar) return;
        const threshold = parseInt(bar.dataset.thresholdCents, 10) || 0;
        if (threshold <= 0) return;
        const total = (cart && typeof cart.total_price === 'number') ? cart.total_price : 0;
        const remaining = Math.max(0, threshold - total);
        const percent = Math.min(100, Math.round((total / threshold) * 100));
        const fill = bar.querySelector('[data-mod-ship-bar-fill]');
        const label = bar.querySelector('[data-mod-ship-bar-label]');
        if (fill) fill.style.width = percent + '%';
        const track = bar.querySelector('.modulus-ship-bar__track');
        if (track) track.setAttribute('aria-valuenow', String(percent));
        const unlocked = total >= threshold;
        bar.classList.toggle('is-unlocked', unlocked);
        if (label) {
          if (unlocked) {
            label.textContent = bar.dataset.unlockedText || '';
          } else {
            const template = bar.dataset.remainingTemplate || 'Add [amount] more for free shipping.';
            label.textContent = template.replace('[amount]', this.formatMoney(remaining));
          }
        }
      }

      formatMoney(cents) {
        if (window.Shopify && typeof Shopify.formatMoney === 'function') {
          return Shopify.formatMoney(cents);
        }
        const amount = (cents / 100).toFixed(2);
        const currency = (window.Shopify && Shopify.currency && Shopify.currency.active) || '';
        return currency ? `${amount} ${currency}` : amount;
      }
    });
  }
{% endjavascript %}

