{% comment %}
  Modulus Contact — contact form section.
  Can be added to any page template; typically wired into templates/
  page.contact.json. Uses Shopify's {% form 'contact' %}.
{% endcomment %}

<div
  id="modulus-contact-{{ section.id }}"
  class="modulus-contact color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="
    --mct-py: {{ section.settings.padding_y }}px;
    --mct-content-width: {{ section.settings.content_max_width }}px;
  "
>
  <div class="modulus-contact__inner">
    <div class="modulus-contact__grid">

      <header class="modulus-contact__head" data-mod-reveal>
        {%- if section.settings.label_text != blank -%}
          {% render 'modulus-section-label',
            text: section.settings.label_text,
            number: section.settings.label_number
          %}
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="modulus-contact__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <div class="modulus-contact__intro">{{ section.settings.intro }}</div>
        {%- endif -%}

        {%- if section.settings.show_meta -%}
          <ul class="modulus-contact__meta" role="list">
            {%- if section.settings.meta_email != blank -%}
              <li>
                <span class="modulus-contact__meta-label">Email</span>
                <a href="mailto:{{ section.settings.meta_email }}">{{ section.settings.meta_email }}</a>
              </li>
            {%- endif -%}
            {%- if section.settings.meta_phone != blank -%}
              <li>
                <span class="modulus-contact__meta-label">Phone</span>
                <a href="tel:{{ section.settings.meta_phone | replace: ' ', '' | replace: '-', '' }}">{{ section.settings.meta_phone }}</a>
              </li>
            {%- endif -%}
            {%- if section.settings.meta_address != blank -%}
              <li>
                <span class="modulus-contact__meta-label">Visit</span>
                <span>{{ section.settings.meta_address }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.meta_hours != blank -%}
              <li>
                <span class="modulus-contact__meta-label">Hours</span>
                <span>{{ section.settings.meta_hours }}</span>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </header>

      <div class="modulus-contact__form-wrap" data-mod-reveal data-mod-reveal-delay="120">
        {% form 'contact', id: 'modulus-contact-form-' | append: section.id, class: 'modulus-contact__form' %}
          {%- if form.posted_successfully? -%}
            <div class="modulus-contact__notice modulus-contact__notice--success" role="status">
              {{ section.settings.success_message | default: "Thanks — we'll get back to you shortly." }}
            </div>
          {%- elsif form.errors -%}
            <div class="modulus-contact__notice modulus-contact__notice--error" role="alert">
              <strong>Please correct the following:</strong>
              <ul>
                {%- for field in form.errors -%}
                  <li>{{ form.errors.messages[field] | escape }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="modulus-contact__field-row">
            <div class="modulus-contact__field">
              <label for="contact-name-{{ section.id }}">Name</label>
              <input
                type="text"
                id="contact-name-{{ section.id }}"
                name="contact[name]"
                autocomplete="name"
                value="{% if form.name %}{{ form.name }}{% elsif customer.name %}{{ customer.name }}{% endif %}"
                required
              >
            </div>
            <div class="modulus-contact__field">
              <label for="contact-email-{{ section.id }}">Email</label>
              <input
                type="email"
                id="contact-email-{{ section.id }}"
                name="contact[email]"
                autocomplete="email"
                value="{% if form.email %}{{ form.email }}{% elsif customer.email %}{{ customer.email }}{% endif %}"
                required
              >
            </div>
          </div>

          {%- if section.settings.show_phone -%}
            <div class="modulus-contact__field">
              <label for="contact-phone-{{ section.id }}">Phone (optional)</label>
              <input
                type="tel"
                id="contact-phone-{{ section.id }}"
                name="contact[phone]"
                autocomplete="tel"
                value="{% if form.phone %}{{ form.phone }}{% endif %}"
              >
            </div>
          {%- endif -%}

          <div class="modulus-contact__field">
            <label for="contact-body-{{ section.id }}">Message</label>
            <textarea
              id="contact-body-{{ section.id }}"
              name="contact[body]"
              rows="6"
              required
            >{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="mod-btn mod-btn--primary modulus-contact__submit">
            <span>{{ section.settings.submit_label | default: 'Send message' }}</span>
            <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
          </button>

          {%- if section.settings.disclaimer != blank -%}
            <p class="modulus-contact__disclaimer">{{ section.settings.disclaimer }}</p>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .modulus-contact {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--mct-py, var(--mod-section-py)) var(--mod-section-px);
  }

  .modulus-contact__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  .modulus-contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--mod-gap-xl);
    align-items: flex-start;
  }

  /* ---- head ---- */

  .modulus-contact__head {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
    position: sticky;
    top: 100px;
  }

  h2.modulus-contact__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(28px, 4.5vw, 56px);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .modulus-contact__heading p { margin: 0; }

  .modulus-contact__intro {
    font-family: var(--font-body--family);
    font-size: clamp(15px, 1.1vw, 17px);
    color: rgb(var(--color-foreground-rgb) / 0.75);
    line-height: 1.65;
  }

  .modulus-contact__intro p { margin: 0; }
  .modulus-contact__intro p + p { margin-top: 0.6em; }

  .modulus-contact__meta {
    list-style: none;
    padding: 0;
    margin: var(--mod-gap-sm) 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: var(--mod-gap-sm);
    border-top: 1px solid var(--color-border);
  }

  .modulus-contact__meta li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 14px;
    align-items: baseline;
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
  }

  .modulus-contact__meta-label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .modulus-contact__meta a {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ---- form ---- */

  .modulus-contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
  }

  .modulus-contact__field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--mod-gap-sm);
  }

  .modulus-contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modulus-contact__field label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .modulus-contact__field input,
  .modulus-contact__field textarea {
    font-family: var(--font-body--family);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: transparent;
    color: var(--color-foreground);
    outline: none;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  .modulus-contact__field textarea {
    resize: vertical;
    min-height: 140px;
  }

  .modulus-contact__field input:focus,
  .modulus-contact__field textarea:focus {
    border-color: var(--color-foreground);
  }

  .modulus-contact__submit {
    align-self: flex-start;
    margin-top: var(--mod-gap-sm);
  }

  .modulus-contact__notice {
    padding: 14px 16px;
    border: 1px solid var(--color-border);
    font-family: var(--font-body--family);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-foreground);
  }

  .modulus-contact__notice--success { border-color: var(--color-foreground); }
  .modulus-contact__notice--error { border-color: var(--color-foreground); }

  .modulus-contact__notice ul {
    margin: 6px 0 0;
    padding-left: 18px;
  }

  .modulus-contact__disclaimer {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    line-height: 1.5;
    margin: 0;
  }

  /* ---- responsive ---- */

  @media (max-width: 1024px) {
    .modulus-contact__grid {
      grid-template-columns: 1fr;
      gap: var(--mod-gap-lg);
    }
    .modulus-contact__head { position: static; }
  }

  @media (max-width: 640px) {
    .modulus-contact__field-row { grid-template-columns: 1fr; }
    .modulus-contact__meta li { grid-template-columns: 70px 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Contact",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "label_text", "label": "Section label", "default": "Get in touch" },
    { "type": "text", "id": "label_number", "label": "Section number", "default": "01" },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Get in touch.</p>"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Questions, project briefs, or partnership requests — we read everything and respond within two working days.</p>"
    },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Send message" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks — we'll get back to you shortly." },
    { "type": "richtext", "id": "disclaimer", "label": "Disclaimer", "default": "<p>By submitting, you agree to our privacy policy.</p>" },

    { "type": "header", "content": "Form fields" },
    { "type": "checkbox", "id": "show_phone", "label": "Show phone field", "default": true },

    { "type": "header", "content": "Contact details" },
    { "type": "checkbox", "id": "show_meta", "label": "Show contact details panel", "default": true },
    { "type": "text", "id": "meta_email", "label": "Email address" },
    { "type": "text", "id": "meta_phone", "label": "Phone number" },
    { "type": "text", "id": "meta_address", "label": "Address" },
    { "type": "text", "id": "meta_hours", "label": "Hours" },

    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full", "label": "Full viewport" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600, "max": 1400, "step": 20, "unit": "px",
      "default": 1120
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40, "max": 240, "step": 4, "unit": "px",
      "default": 120
    },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [{ "name": "Modulus Contact" }],
  "enabled_on": {
    "templates": ["page"]
  }
}
{% endschema %}
