{% comment %}
  Modulus Customers · Reset password — set a new password via email link.
{% endcomment %}

<div
  id="modulus-cust-reset-{{ section.id }}"
  class="modulus-cust modulus-cust--auth color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--mc-py: {{ section.settings.padding_y }}px;"
>
  <div class="modulus-cust__inner modulus-cust__inner--auth">
    <div class="modulus-cust__panel" data-mod-reveal>
      <header class="modulus-cust__header">
        <h1 class="modulus-cust__heading">{{ section.settings.heading | default: 'Reset your password' }}</h1>
        <p class="modulus-cust__subtitle">{{ section.settings.subtitle | default: 'Pick a new password for your account.' }}</p>
      </header>

      {% form 'reset_customer_password' %}
        {%- if form.errors -%}
          <div class="modulus-cust__notice modulus-cust__notice--error" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="modulus-cust__field">
          <label for="cust-reset-password-{{ section.id }}">New password</label>
          <input type="password" id="cust-reset-password-{{ section.id }}" name="customer[password]" autocomplete="new-password" required>
        </div>

        <div class="modulus-cust__field">
          <label for="cust-reset-confirm-{{ section.id }}">Confirm password</label>
          <input type="password" id="cust-reset-confirm-{{ section.id }}" name="customer[password_confirmation]" autocomplete="new-password" required>
        </div>

        <button type="submit" class="mod-btn mod-btn--primary modulus-cust__submit">
          <span>{{ section.settings.submit_label | default: 'Set password' }}</span>
          <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
        </button>
      {% endform %}

      <div class="modulus-cust__extra">
        <p class="modulus-cust__alt-cta">
          <a href="{{ routes.account_login_url }}">Back to sign in</a>
        </p>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .modulus-cust { background: var(--color-background); color: var(--color-foreground); padding: var(--mc-py, var(--mod-section-py)) var(--mod-section-px); }
  .modulus-cust__inner { width: 100%; max-width: var(--mod-max-width); margin: 0 auto; }
  .modulus-cust__inner--auth { display: flex; align-items: center; justify-content: center; min-height: 60vh; }
  .modulus-cust__panel { width: 100%; max-width: 480px; border: 1px solid var(--color-border); padding: clamp(28px, 4vw, 48px); display: flex; flex-direction: column; gap: var(--mod-gap-sm); }
  .modulus-cust__header { display: flex; flex-direction: column; gap: 6px; margin-bottom: var(--mod-gap-sm); }
  h1.modulus-cust__heading { font-family: var(--font-heading--family); font-weight: var(--font-heading--weight); font-size: clamp(24px, 3vw, 36px); color: var(--color-foreground-heading, var(--color-foreground)); line-height: 1.1; letter-spacing: -0.01em; margin: 0; }
  .modulus-cust__subtitle { font-family: var(--font-body--family); font-size: 14px; color: rgb(var(--color-foreground-rgb) / 0.7); line-height: 1.55; margin: 0; }
  .modulus-cust__field { display: flex; flex-direction: column; gap: 6px; margin-bottom: var(--mod-gap-sm); }
  .modulus-cust__field label { font-family: var(--font-label--family, var(--font-body--family)); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: rgb(var(--color-foreground-rgb) / 0.7); }
  .modulus-cust__field input { font-family: var(--font-body--family); font-size: 15px; padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 0; background: transparent; color: var(--color-foreground); outline: none; transition: border-color 0.2s ease; }
  .modulus-cust__field input:focus { border-color: var(--color-foreground); }
  .modulus-cust__submit { align-self: flex-start; justify-content: center; }
  .modulus-cust__notice { padding: 12px 14px; border: 1px solid var(--color-border); font-family: var(--font-body--family); font-size: 13px; line-height: 1.5; margin-bottom: var(--mod-gap-sm); }
  .modulus-cust__notice--error { border-color: var(--color-foreground); }
  .modulus-cust__extra { margin-top: var(--mod-gap-sm); padding-top: var(--mod-gap-sm); border-top: 1px solid var(--color-border); }
  .modulus-cust__alt-cta { font-family: var(--font-body--family); font-size: 13px; color: rgb(var(--color-foreground-rgb) / 0.7); margin: 0; }
  .modulus-cust__alt-cta a { color: var(--color-foreground); text-decoration: underline; text-underline-offset: 3px; }
{% endstylesheet %}

{% schema %}
{
  "name": "Modulus Reset password",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Reset your password" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Pick a new password for your account." },
    { "type": "text", "id": "submit_label", "label": "Submit label", "default": "Set password" },
    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "constrained", "label": "Constrained to page width" }, { "value": "full", "label": "Full viewport" }], "default": "full" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_y", "label": "Vertical padding", "min": 40, "max": 240, "step": 4, "unit": "px", "default": 96 },
    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [{ "name": "Modulus Reset password" }],
  "enabled_on": {
    "templates": ["customers/reset_password"]
  }
}
{% endschema %}
