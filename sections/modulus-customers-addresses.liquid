{% comment %}
  Modulus Customers · Addresses — add / edit / delete customer addresses.
{% endcomment %}

<div
  id="modulus-cust-addresses-{{ section.id }}"
  class="modulus-cust modulus-cust--addresses color-{{ section.settings.color_scheme.id }} {% if section.settings.section_width == 'full' %}full-width{% endif %}{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}"
  style="--mc-py: {{ section.settings.padding_y }}px;"
>
  <div class="modulus-cust__inner">
    <header class="modulus-cust__account-head" data-mod-reveal>
      <h1 class="modulus-cust__account-heading">{{ section.settings.heading | default: 'Addresses' }}</h1>
      <p class="modulus-cust__account-sub"><a href="{{ routes.account_url }}">← Back to account</a></p>
    </header>

    <div class="modulus-cust__account-grid">
      <aside class="modulus-cust__nav" aria-label="Account navigation" data-mod-reveal>
        <ul role="list">
          <li><a href="{{ routes.account_url }}">Overview</a></li>
          <li><a href="{{ routes.account_addresses_url }}" aria-current="page">Addresses</a></li>
          <li><a href="{{ routes.account_logout_url }}">Sign out</a></li>
        </ul>
      </aside>

      <main class="modulus-cust__main">

        <section class="modulus-cust__card" data-mod-reveal data-mod-reveal-delay="80">
          <div class="modulus-cust__card-head">
            <h2 class="modulus-cust__card-heading">Add a new address</h2>
          </div>

          {% form 'customer_address', customer.new_address %}
            {%- if form.errors -%}
              <div class="modulus-cust__notice modulus-cust__notice--error" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            <div class="modulus-cust__field-row">
              <div class="modulus-cust__field">
                <label for="new-first-{{ section.id }}">First name</label>
                <input type="text" id="new-first-{{ section.id }}" name="address[first_name]" autocomplete="given-name">
              </div>
              <div class="modulus-cust__field">
                <label for="new-last-{{ section.id }}">Last name</label>
                <input type="text" id="new-last-{{ section.id }}" name="address[last_name]" autocomplete="family-name">
              </div>
            </div>

            <div class="modulus-cust__field">
              <label for="new-company-{{ section.id }}">Company (optional)</label>
              <input type="text" id="new-company-{{ section.id }}" name="address[company]" autocomplete="organization">
            </div>

            <div class="modulus-cust__field">
              <label for="new-address1-{{ section.id }}">Address</label>
              <input type="text" id="new-address1-{{ section.id }}" name="address[address1]" autocomplete="address-line1">
            </div>

            <div class="modulus-cust__field">
              <label for="new-address2-{{ section.id }}">Apartment, suite, etc. (optional)</label>
              <input type="text" id="new-address2-{{ section.id }}" name="address[address2]" autocomplete="address-line2">
            </div>

            <div class="modulus-cust__field-row">
              <div class="modulus-cust__field">
                <label for="new-city-{{ section.id }}">City</label>
                <input type="text" id="new-city-{{ section.id }}" name="address[city]" autocomplete="address-level2">
              </div>
              <div class="modulus-cust__field">
                <label for="new-country-{{ section.id }}">Country</label>
                <select
                  id="new-country-{{ section.id }}"
                  name="address[country]"
                  data-default="{{ form.country | escape }}"
                  autocomplete="country"
                >
                  {{ all_country_option_tags }}
                </select>
              </div>
            </div>

            <div class="modulus-cust__field-row">
              <div class="modulus-cust__field">
                <label for="new-province-{{ section.id }}">State / Province</label>
                <select id="new-province-{{ section.id }}" name="address[province]" autocomplete="address-level1" data-default="{{ form.province | escape }}"></select>
              </div>
              <div class="modulus-cust__field">
                <label for="new-zip-{{ section.id }}">Postal / ZIP code</label>
                <input type="text" id="new-zip-{{ section.id }}" name="address[zip]" autocomplete="postal-code">
              </div>
            </div>

            <div class="modulus-cust__field">
              <label for="new-phone-{{ section.id }}">Phone (optional)</label>
              <input type="tel" id="new-phone-{{ section.id }}" name="address[phone]" autocomplete="tel">
            </div>

            <label class="modulus-cust__checkbox">
              <input type="checkbox" name="address[default]" value="1">
              <span>Set as default address</span>
            </label>

            <button type="submit" class="mod-btn mod-btn--primary modulus-cust__submit">
              <span>Save address</span>
              <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
            </button>
          {% endform %}
        </section>

        <section class="modulus-cust__card" data-mod-reveal data-mod-reveal-delay="120">
          <div class="modulus-cust__card-head">
            <h2 class="modulus-cust__card-heading">Your addresses</h2>
            <span class="modulus-cust__card-meta">{{ customer.addresses_count }} total</span>
          </div>

          {%- if customer.addresses.size > 0 -%}
            {%- paginate customer.addresses by 6 -%}
              <ul class="modulus-cust__addr-list" role="list">
                {%- for address in customer.addresses -%}
                  <li class="modulus-cust__addr">
                    <div class="modulus-cust__addr-info">
                      {%- if address == customer.default_address -%}
                        <span class="modulus-cust__badge">Default</span>
                      {%- endif -%}
                      <div class="modulus-cust__addr-body">{{ address | format_address }}</div>
                    </div>

                    <div class="modulus-cust__addr-actions">
                      <details class="modulus-cust__addr-edit">
                        <summary>Edit</summary>
                        <div class="modulus-cust__addr-edit-inner">
                          {% form 'customer_address', address %}
                            {%- if form.errors -%}
                              <div class="modulus-cust__notice modulus-cust__notice--error" role="alert">
                                {{ form.errors | default_errors }}
                              </div>
                            {%- endif -%}

                            {%- liquid
                              assign edit_first_name = form.first_name | default: address.first_name
                              assign edit_last_name = form.last_name | default: address.last_name
                              assign edit_company = form.company | default: address.company
                              assign edit_address1 = form.address1 | default: address.address1
                              assign edit_address2 = form.address2 | default: address.address2
                              assign edit_city = form.city | default: address.city
                              assign edit_country = form.country | default: address.country
                              assign edit_province = form.province | default: address.province
                              assign edit_zip = form.zip | default: address.zip
                              assign edit_phone = form.phone | default: address.phone
                            -%}

                            <div class="modulus-cust__field-row">
                              <div class="modulus-cust__field">
                                <label>First name</label>
                                <input type="text" name="address[first_name]" value="{{ edit_first_name | escape }}">
                              </div>
                              <div class="modulus-cust__field">
                                <label>Last name</label>
                                <input type="text" name="address[last_name]" value="{{ edit_last_name | escape }}">
                              </div>
                            </div>

                            <div class="modulus-cust__field">
                              <label>Company (optional)</label>
                              <input type="text" name="address[company]" value="{{ edit_company | escape }}">
                            </div>

                            <div class="modulus-cust__field">
                              <label>Address</label>
                              <input type="text" name="address[address1]" value="{{ edit_address1 | escape }}">
                            </div>

                            <div class="modulus-cust__field">
                              <label>Apt, suite, etc. (optional)</label>
                              <input type="text" name="address[address2]" value="{{ edit_address2 | escape }}">
                            </div>

                            <div class="modulus-cust__field-row">
                              <div class="modulus-cust__field">
                                <label>City</label>
                                <input type="text" name="address[city]" value="{{ edit_city | escape }}">
                              </div>
                              <div class="modulus-cust__field">
                                <label>Country</label>
                                <select name="address[country]" data-default="{{ edit_country | escape }}">{{ all_country_option_tags }}</select>
                              </div>
                            </div>

                            <div class="modulus-cust__field-row">
                              <div class="modulus-cust__field">
                                <label>State / Province</label>
                                <select name="address[province]" data-default="{{ edit_province | escape }}"></select>
                              </div>
                              <div class="modulus-cust__field">
                                <label>Postal / ZIP code</label>
                                <input type="text" name="address[zip]" value="{{ edit_zip | escape }}">
                              </div>
                            </div>

                            <div class="modulus-cust__field">
                              <label>Phone (optional)</label>
                              <input type="tel" name="address[phone]" value="{{ edit_phone | escape }}">
                            </div>

                            <label class="modulus-cust__checkbox">
                              <input type="checkbox" name="address[default]" value="1" {% if address == customer.default_address %}checked{% endif %}>
                              <span>Default address</span>
                            </label>

                            <div class="modulus-cust__addr-edit-actions">
                              <button type="submit" class="modulus-cust__submit--ghost">Save changes</button>
                            </div>
                          {% endform %}

                          <form method="post" action="{{ address.url }}" class="modulus-cust__addr-delete">
                            <input type="hidden" name="_method" value="delete">
                            <button type="submit" data-confirm="Delete this address?">Delete address</button>
                          </form>
                        </div>
                      </details>
                    </div>
                  </li>
                {%- endfor -%}
              </ul>

              {%- if paginate.pages > 1 -%}
                <nav class="modulus-cust__pagination" aria-label="Addresses pagination">
                  {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">← Prev</a>{%- endif -%}
                  <span>Page {{ paginate.current_page }} / {{ paginate.pages }}</span>
                  {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
                </nav>
              {%- endif -%}
            {%- endpaginate -%}
          {%- else -%}
            <p class="modulus-cust__empty">You don't have any saved addresses yet.</p>
          {%- endif -%}
        </section>

      </main>
    </div>
  </div>
</div>

{% stylesheet %}
  .modulus-cust {
    background: var(--color-background);
    color: var(--color-foreground);
    padding: var(--mc-py, var(--mod-section-py)) var(--mod-section-px);
  }

  .modulus-cust__inner {
    width: 100%;
    max-width: var(--mod-max-width);
    margin: 0 auto;
  }

  /* shared heads/grids — same as account section */

  .modulus-cust__account-head {
    display: flex;
    flex-direction: column;
    gap: var(--mod-gap-sm);
    padding-bottom: var(--mod-gap-md);
    margin-bottom: var(--mod-gap-lg);
    border-bottom: 1px solid var(--color-border);
  }

  h1.modulus-cust__account-heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(32px, 5vw, 64px);
    color: var(--color-foreground-heading, var(--color-foreground));
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .modulus-cust__account-sub {
    font-family: var(--font-body--family);
    font-size: 14px;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    margin: 0;
  }
  .modulus-cust__account-sub a { color: inherit; text-decoration: underline; text-underline-offset: 3px; }

  .modulus-cust__account-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: var(--mod-gap-lg);
    align-items: flex-start;
  }

  .modulus-cust__nav { position: sticky; top: 100px; }
  .modulus-cust__nav ul { list-style: none; padding: 0; margin: 0; }
  .modulus-cust__nav a {
    display: block; padding: 10px 0;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .modulus-cust__nav a:hover,
  .modulus-cust__nav a[aria-current='page'] {
    color: var(--color-foreground);
    border-bottom-color: var(--color-foreground);
  }

  .modulus-cust__main { display: flex; flex-direction: column; gap: var(--mod-gap-lg); }

  .modulus-cust__card { border: 1px solid var(--color-border); padding: clamp(20px, 2vw, 28px); }

  .modulus-cust__card-head {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 16px; padding-bottom: 12px; margin-bottom: var(--mod-gap-sm);
    border-bottom: 1px solid var(--color-border);
  }

  h2.modulus-cust__card-heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 20px; margin: 0;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .modulus-cust__card-meta {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  /* ---- fields ---- */
  .modulus-cust__field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .modulus-cust__field { display: flex; flex-direction: column; gap: 6px; margin-bottom: var(--mod-gap-sm); }
  .modulus-cust__field label {
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }
  .modulus-cust__field input,
  .modulus-cust__field select {
    font-family: var(--font-body--family);
    font-size: 15px;
    padding: 12px 14px;
    border: 1px solid var(--color-border);
    border-radius: 0;
    background: transparent;
    color: var(--color-foreground);
    outline: none;
    transition: border-color 0.2s ease;
  }
  .modulus-cust__field input:focus,
  .modulus-cust__field select:focus { border-color: var(--color-foreground); }

  .modulus-cust__checkbox {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--mod-gap-sm);
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
    cursor: pointer;
  }

  .modulus-cust__submit { align-self: flex-start; justify-content: center; }
  .modulus-cust__submit--ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; background: transparent; color: var(--color-foreground);
    border: 1px solid var(--color-border);
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .modulus-cust__submit--ghost:hover { background: var(--color-foreground); color: var(--color-background); }

  .modulus-cust__notice {
    padding: 12px 14px; border: 1px solid var(--color-border);
    font-family: var(--font-body--family);
    font-size: 13px; line-height: 1.5; margin-bottom: var(--mod-gap-sm);
  }
  .modulus-cust__notice--error { border-color: var(--color-foreground); }

  .modulus-cust__empty {
    font-family: var(--font-body--family);
    font-size: 14px; color: rgb(var(--color-foreground-rgb) / 0.65);
    margin: 0; padding: 24px 0; text-align: center;
  }

  /* ---- address list ---- */
  .modulus-cust__addr-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--mod-gap-sm); }

  .modulus-cust__addr {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    flex-wrap: wrap;
  }

  .modulus-cust__addr-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; }

  .modulus-cust__badge {
    display: inline-block; align-self: flex-start;
    padding: 3px 8px; border: 1px solid var(--color-foreground);
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--color-foreground);
  }

  .modulus-cust__addr-body {
    font-family: var(--font-body--family);
    font-size: 14px; line-height: 1.6;
    color: var(--color-foreground);
  }

  .modulus-cust__addr-actions { flex-shrink: 0; }

  .modulus-cust__addr-edit summary {
    cursor: pointer;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-foreground);
    list-style: none;
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .modulus-cust__addr-edit summary::-webkit-details-marker { display: none; }
  .modulus-cust__addr-edit summary::marker { content: ''; }
  .modulus-cust__addr-edit[open] summary,
  .modulus-cust__addr-edit summary:hover { background: var(--color-foreground); color: var(--color-background); }

  .modulus-cust__addr-edit-inner {
    width: 100%;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  .modulus-cust__addr-edit-actions {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .modulus-cust__addr-delete button {
    background: transparent;
    border: none;
    padding: 8px 0;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.75);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .modulus-cust__addr-delete button:hover { color: var(--color-foreground); }

  .modulus-cust__pagination {
    display: flex; align-items: center; justify-content: center; gap: 24px;
    margin-top: var(--mod-gap-md);
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }
  .modulus-cust__pagination a { color: var(--color-foreground); text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 2px; }

  @media (max-width: 900px) {
    .modulus-cust__account-grid { grid-template-columns: 1fr; }
    .modulus-cust__nav { position: static; }
    .modulus-cust__nav ul { display: flex; gap: 4px; flex-wrap: wrap; }
    .modulus-cust__nav a { border-bottom: none; padding: 10px 16px; border: 1px solid var(--color-border); }
    .modulus-cust__nav a[aria-current='page'] { background: var(--color-foreground); color: var(--color-background); border-color: var(--color-foreground); }
    .modulus-cust__addr { flex-direction: column; }
  }

  @media (max-width: 480px) {
    .modulus-cust__field-row { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    // Province selector sync via Shopify's CountryProvinceSelector if available
    document.querySelectorAll('select[name="address[country]"]').forEach(function (countrySelect) {
      var provinceSelect = countrySelect.closest('form, details, section').querySelector('select[name="address[province]"]');
      if (!provinceSelect) return;
      if (typeof Shopify !== 'undefined' && Shopify.CountryProvinceSelector) {
        new Shopify.CountryProvinceSelector(countrySelect.id, provinceSelect.id, {
          hideElement: provinceSelect.parentElement
        });
      }
      var defaultCountry = countrySelect.dataset.default;
      if (defaultCountry) {
        var opt = countrySelect.querySelector('option[value="' + defaultCountry + '"]');
        if (opt) opt.selected = true;
      }
    });

    // Delete confirm
    document.querySelectorAll('.modulus-cust__addr-delete').forEach(function (form) {
      form.addEventListener('submit', function (e) {
        var btn = form.querySelector('button[data-confirm]');
        if (!btn) return;
        if (!window.confirm(btn.dataset.confirm || 'Delete?')) {
          e.preventDefault();
        }
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Modulus Addresses",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Addresses" },

    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "constrained", "label": "Constrained to page width" },
        { "value": "full", "label": "Full viewport" }
      ],
      "default": "full"
    },

    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 40, "max": 240, "step": 4, "unit": "px",
      "default": 96
    },

    { "type": "header", "content": "Advanced" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" }
  ],
  "presets": [{ "name": "Modulus Addresses" }],
  "enabled_on": {
    "templates": ["customers/addresses"]
  }
}
{% endschema %}
