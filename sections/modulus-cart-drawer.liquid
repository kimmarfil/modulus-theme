{% comment %}
  Modulus Cart Drawer — slide-in cart triggered from the header cart icon.
  Stays in the DOM on every page; opens in response to [data-mod-cart-open]
  clicks, custom events (modulus:cart:open), or any <form action="/cart/add">
  submission (enhanced → opens the drawer after add-to-cart succeeds).
{% endcomment %}

<modulus-cart-drawer
  id="modulus-cart-drawer"
  class="modulus-cart-drawer color-{{ section.settings.color_scheme.id }}"
  data-shopify-section-id="{{ section.id }}"
  aria-hidden="true"
>
  <div class="modulus-cart-drawer__overlay" data-mod-cart-backdrop></div>

  <aside
    class="modulus-cart-drawer__panel"
    data-mod-cart-panel
    role="dialog"
    aria-label="Cart"
    aria-modal="true"
    tabindex="-1"
  >
    <header class="modulus-cart-drawer__head">
      <h2 class="modulus-cart-drawer__heading">
        {{ section.settings.heading | default: 'Cart' }}
        <span class="modulus-cart-drawer__count" data-mod-cart-count>({{ cart.item_count }})</span>
      </h2>
      <button type="button" class="modulus-cart-drawer__close" data-mod-cart-close aria-label="Close cart">
        {% render 'modulus-icon', name: 'close', size: 18 %}
      </button>
    </header>

    <div class="modulus-cart-drawer__body" data-mod-cart-body>
      {%- render 'modulus-cart-drawer-body', cart: cart, section: section -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <footer class="modulus-cart-drawer__foot" data-mod-cart-foot>
        <div class="modulus-cart-drawer__subtotal">
          <span>Subtotal</span>
          <span data-mod-cart-total>{{ cart.total_price | money }}</span>
        </div>
        <p class="modulus-cart-drawer__note">
          {{ section.settings.tax_note | default: 'Taxes and shipping calculated at checkout.' }}
        </p>
        <a href="{{ routes.cart_url }}" class="modulus-cart-drawer__view-cart">
          {{ section.settings.view_cart_label | default: 'View cart' }}
        </a>
        <form action="{{ routes.cart_url }}" method="post" novalidate>
          <button type="submit" name="checkout" class="mod-btn mod-btn--primary modulus-cart-drawer__checkout">
            <span>{{ section.settings.checkout_label | default: 'Checkout' }}</span>
            <span class="mod-btn__arrow" aria-hidden="true">{% render 'modulus-icon', name: 'arrow-right', size: 14 %}</span>
          </button>
        </form>
      </footer>
    {%- endif -%}
  </aside>
</modulus-cart-drawer>

{% stylesheet %}
  .modulus-cart-drawer {
    display: block;
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 110;
    /* The outer container must stay transparent even when a .color-scheme-*
       class (which sets background-color: var(--color-background)) is applied
       to it — otherwise it paints a solid rectangle over the entire viewport
       and the page goes blank. The backdrop + panel children render their
       own backgrounds when the drawer opens. */
    background: transparent !important;
  }

  .modulus-cart-drawer.is-open {
    pointer-events: auto;
  }

  .modulus-cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .modulus-cart-drawer.is-open .modulus-cart-drawer__overlay {
    opacity: 1;
  }

  .modulus-cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(480px, 92vw);
    background: var(--color-background);
    color: var(--color-foreground);
    border-left: 1px solid var(--color-border);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .modulus-cart-drawer.is-open .modulus-cart-drawer__panel {
    transform: translateX(0);
  }

  /* ---- head ---- */

  .modulus-cart-drawer__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px var(--mod-section-px, 24px);
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  h2.modulus-cart-drawer__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 22px;
    color: var(--color-foreground-heading, var(--color-foreground));
    margin: 0;
    letter-spacing: -0.005em;
  }

  .modulus-cart-drawer__count {
    font-weight: 400;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin-left: 6px;
    font-size: 16px;
  }

  .modulus-cart-drawer__close {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .modulus-cart-drawer__close:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ---- body ---- */

  .modulus-cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 8px var(--mod-section-px, 24px);
  }

  .modulus-cart-drawer__empty {
    padding: 40px 8px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .modulus-cart-drawer__empty p {
    font-family: var(--font-body--family);
    font-size: 15px;
    color: rgb(var(--color-foreground-rgb) / 0.7);
    line-height: 1.55;
    margin: 0;
    max-width: 320px;
  }

  /* ---- line items ---- */

  .modulus-cart-drawer__lines {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .modulus-cart-drawer__line {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .modulus-cart-drawer__line-img {
    width: 80px;
    aspect-ratio: 1;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .modulus-cart-drawer__line-img img,
  .modulus-cart-drawer__line-img svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modulus-cart-drawer__line-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .modulus-cart-drawer__line-title {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 14px;
    color: var(--color-foreground);
    text-decoration: none;
    line-height: 1.3;
  }

  .modulus-cart-drawer__line-variant {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.65);
  }

  .modulus-cart-drawer__line-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 6px;
    gap: 12px;
  }

  .modulus-cart-drawer__qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border);
  }

  .modulus-cart-drawer__qty button {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--color-foreground);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .modulus-cart-drawer__qty button:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .modulus-cart-drawer__qty input {
    width: 36px;
    height: 28px;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    background: transparent;
    text-align: center;
    font-family: var(--font-body--family);
    font-size: 13px;
    color: var(--color-foreground);
    appearance: textfield;
    -moz-appearance: textfield;
  }

  .modulus-cart-drawer__qty input::-webkit-inner-spin-button,
  .modulus-cart-drawer__qty input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .modulus-cart-drawer__line-total {
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--color-foreground);
  }

  .modulus-cart-drawer__line-remove {
    background: transparent;
    border: none;
    padding: 4px 0;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    align-self: flex-start;
  }

  .modulus-cart-drawer__line-remove:hover { color: var(--color-foreground); }

  /* ---- foot ---- */

  .modulus-cart-drawer__foot {
    padding: 16px var(--mod-section-px, 24px) 20px;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-shrink: 0;
    background: var(--color-background);
  }

  .modulus-cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-body--family);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .modulus-cart-drawer__note {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.6);
    line-height: 1.5;
    margin: 0;
  }

  .modulus-cart-drawer__view-cart {
    display: inline-block;
    text-align: center;
    padding: 10px 0;
    font-family: var(--font-label--family, var(--font-body--family));
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border: 1px solid var(--color-border);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .modulus-cart-drawer__view-cart:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .modulus-cart-drawer__checkout {
    width: 100%;
    justify-content: center;
    padding: 16px 24px;
  }

  /* ---- loading ---- */

  .modulus-cart-drawer.is-loading .modulus-cart-drawer__body {
    opacity: 0.55;
    pointer-events: none;
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('modulus-cart-drawer')) {
    customElements.define('modulus-cart-drawer', class ModulusCartDrawer extends HTMLElement {
      connectedCallback() {
        this.body = this.querySelector('[data-mod-cart-body]');
        this.foot = this.querySelector('[data-mod-cart-foot]');
        this.countEls = document.querySelectorAll('[data-mod-cart-count]');
        this.panel = this.querySelector('[data-mod-cart-panel]');
        this.overlay = this.querySelector('[data-mod-cart-backdrop]');
        this.closeBtn = this.querySelector('[data-mod-cart-close]');

        if (this.closeBtn) this.closeBtn.addEventListener('click', () => this.close());
        if (this.overlay) this.overlay.addEventListener('click', () => this.close());

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.classList.contains('is-open')) this.close();
        });

        document.addEventListener('click', (e) => {
          const trigger = e.target.closest('[data-mod-cart-open]');
          if (trigger) {
            e.preventDefault();
            this.open();
          }
        });

        window.addEventListener('modulus:cart:open', () => this.open());
        window.addEventListener('modulus:cart:update', (e) => this.render(e.detail));

        this.bindFormIntercepts();
        this.bindBodyInteractions();
      }

      open() {
        this._opener = document.activeElement;
        this.classList.add('is-open');
        this.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modulus-header-drawer-open');
        if (this.panel) this.panel.focus();
        this.refresh();
        if (!this._trap) {
          this._trap = (e) => this._trapTab(e);
          (this.panel || this).addEventListener('keydown', this._trap);
        }
      }

      close() {
        this.classList.remove('is-open');
        this.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('modulus-header-drawer-open');
        if (this._trap) {
          (this.panel || this).removeEventListener('keydown', this._trap);
          this._trap = null;
        }
        if (this._opener && typeof this._opener.focus === 'function') {
          this._opener.focus();
          this._opener = null;
        }
      }

      _trapTab(e) {
        if (e.key !== 'Tab') return;
        const container = this.panel || this;
        const sel = 'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])';
        const focusables = Array.from(container.querySelectorAll(sel)).filter((el) => el.offsetParent !== null);
        if (!focusables.length) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      // Intercept product-form add-to-cart submits so we can POST via
      // /cart/add.js and open the drawer with the updated cart.
      // Bind exactly once globally — the theme editor re-runs
      // connectedCallback on every setting change, which would otherwise
      // stack listeners and cause duplicate /cart/add.js requests.
      bindFormIntercepts() {
        if (window.__modulusCartDrawerGlobalBound) return;
        window.__modulusCartDrawerGlobalBound = true;
        document.addEventListener('submit', (e) => {
          const form = e.target.closest('form[action$="/cart/add"]');
          if (!form) return;
          const drawer = document.querySelector('modulus-cart-drawer');
          if (!drawer) return;
          e.preventDefault();
          const fd = new FormData(form);
          // Each add-to-cart gets its own AbortController so a slow /add
          // doesn't block a quicker subsequent click.
          const controller = new AbortController();
          const timeout = setTimeout(() => controller.abort(), 10000);
          drawer.classList.add('is-loading');
          fetch('/cart/add.js', {
            method: 'POST',
            body: fd,
            headers: { 'Accept': 'application/json' },
            signal: controller.signal
          })
            .then((r) => r.ok ? r.json() : Promise.reject(r.status))
            .then(() => drawer.refresh())
            .then(() => drawer.open())
            .catch((err) => {
              // On timeout / network error / non-2xx, fall back to the
              // native form submission so the user isn't stuck silently.
              if (err && err.name === 'AbortError') return;
              form.submit();
            })
            .finally(() => {
              clearTimeout(timeout);
              drawer.classList.remove('is-loading');
            });
        });
      }

      bindBodyInteractions() {
        if (!this.body) return;
        this.body.addEventListener('click', (e) => {
          const remove = e.target.closest('[data-mod-drawer-remove]');
          if (remove) {
            e.preventDefault();
            this.update(remove.dataset.key, 0);
            return;
          }
          const step = e.target.closest('[data-mod-drawer-step]');
          if (step) {
            e.preventDefault();
            const line = step.closest('[data-mod-drawer-line]');
            const input = line && line.querySelector('[data-mod-drawer-qty-input]');
            if (!input) return;
            const delta = parseInt(step.dataset.mod_drawer_step || step.dataset.modDrawerStep || '1', 10);
            const next = Math.max(0, (parseInt(input.value, 10) || 0) + delta);
            input.value = next;
            this.update(input.dataset.key, next);
          }
        });

        this.body.addEventListener('change', (e) => {
          const input = e.target.closest('[data-mod-drawer-qty-input]');
          if (!input) return;
          const qty = Math.max(0, parseInt(input.value, 10) || 0);
          input.value = qty;
          this.update(input.dataset.key, qty);
        });
      }

      // Fetch wrapper with a 6 s timeout + AbortController. Returns the
      // raw response so callers can decide how to parse (.json() / .text()).
      _fetchWithTimeout(url, options, timeoutMs) {
        options = options || {};
        const controller = new AbortController();
        const signal = controller.signal;
        const timeout = setTimeout(() => controller.abort(), timeoutMs || 6000);
        return fetch(url, Object.assign({ signal }, options))
          .finally(() => clearTimeout(timeout));
      }

      update(key, qty) {
        // Cancel any in-flight update before starting a new one — otherwise
        // rapid clicks on the qty stepper can produce out-of-order responses
        // that overwrite fresher cart state.
        if (this._updateAbort) this._updateAbort.abort();
        this._updateAbort = new AbortController();

        this.classList.add('is-loading');
        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: key, quantity: qty }),
          signal: this._updateAbort.signal
        })
          .then((r) => r.json())
          .then((cart) => {
            this.render(cart);
            window.dispatchEvent(new CustomEvent('modulus:cart:update', { detail: cart }));
          })
          .catch((err) => {
            if (err && err.name === 'AbortError') return;
          })
          .finally(() => this.classList.remove('is-loading'));
      }

      refresh() {
        this._fetchWithTimeout('/cart.js', { headers: { 'Accept': 'application/json' } })
          .then((r) => r.ok ? r.json() : null)
          .then((cart) => { if (cart) this.render(cart); })
          .catch(() => {});
      }

      render(cart) {
        if (!cart || typeof cart.item_count !== 'number') return;
        this.countEls.forEach((el) => {
          el.textContent = cart.item_count;
          if (el.classList.contains('modulus-header__cart-count')) {
            el.classList.toggle('is-empty', cart.item_count === 0);
          }
        });

        // Re-fetch section HTML via Shopify's Section Rendering API for a
        // faithful render (Liquid-rendered markup, including prices + money
        // formatting, rather than rebuilding client-side). Timeout so a slow
        // storefront doesn't leave the drawer stuck on stale markup.
        const sectionId = this.dataset.shopifySectionId;
        if (!sectionId) return;
        if (this._renderAbort) this._renderAbort.abort();
        this._renderAbort = new AbortController();
        const renderTimeout = setTimeout(() => this._renderAbort.abort(), 6000);
        fetch(`${window.location.pathname}?section_id=${encodeURIComponent(sectionId)}`, {
          headers: { 'Accept': 'text/html' },
          signal: this._renderAbort.signal
        })
          .then((r) => r.text())
          .then((html) => {
            const doc = new DOMParser().parseFromString(html, 'text/html');
            const newBody = doc.querySelector('[data-mod-cart-body]');
            const newFoot = doc.querySelector('[data-mod-cart-foot]');
            if (newBody && this.body) this.body.innerHTML = newBody.innerHTML;
            // Foot may or may not be present depending on item_count — replace in place.
            if (this.foot && !newFoot) {
              this.foot.remove();
              this.foot = null;
            } else if (!this.foot && newFoot) {
              this.panel.appendChild(newFoot);
              this.foot = newFoot;
            } else if (this.foot && newFoot) {
              this.foot.replaceWith(newFoot);
              this.foot = newFoot;
            }
          })
          .catch(() => {})
          .finally(() => {
            clearTimeout(renderTimeout);
          });
      }
    });
  }
{% endjavascript %}

{% schema %}
{
  "name": "Modulus Cart drawer",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Cart" },
    { "type": "text", "id": "view_cart_label", "label": "View cart label", "default": "View cart" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "Checkout" },
    { "type": "text", "id": "tax_note", "label": "Tax note", "default": "Taxes and shipping calculated at checkout." },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "Your cart is empty" },
    { "type": "richtext", "id": "empty_text", "label": "Empty body", "default": "<p>Add something worth keeping.</p>" },
    { "type": "text", "id": "empty_cta_label", "label": "Empty CTA label", "default": "Continue shopping" },

    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
