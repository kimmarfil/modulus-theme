<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Modulus design tokens — needed for the password landing section %}
    {{ 'modulus-tokens.css' | asset_url | stylesheet_tag }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    <script src="{{ 'modulus-reveal.js' | asset_url }}" defer></script>
  </head>

  <body>
    {{ content_for_layout }}
  </body>
</html>
